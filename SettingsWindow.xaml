<Window x:Class="OoiMRR.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinWidth="600" MinHeight="400">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标签页 -->
        <TabControl Grid.Row="1" Name="SettingsTabControl">
            <!-- 路径设置页 -->
            <TabItem Header="路径">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <StackPanel>
                        <TextBlock Text="路径设置" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="路径相关设置功能即将推出..." 
                                  Foreground="Gray" FontStyle="Italic"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- 库设置页 -->
            <TabItem Header="库">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <StackPanel>
                        <TextBlock Text="库设置" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="库相关设置功能即将推出..." 
                                  Foreground="Gray" FontStyle="Italic"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- 标签设置页 -->
            <TabItem Header="标签" Name="TagSettingsTab">
                <Grid Name="TagSettingsContainer">
                    <!-- TagTrain设置将在这里动态加载 -->
                </Grid>
            </TabItem>
        </TabControl>
        
        <!-- 底部按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="确定" Click="OK_Click" Padding="20,5" Margin="0,0,10,0" MinWidth="80"/>
            <Button Content="取消" Click="Cancel_Click" Padding="20,5" MinWidth="80"/>
        </StackPanel>
    </Grid>
</Window>



















