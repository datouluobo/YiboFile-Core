<Window x:Class="OoiMRR.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OoiMRR"
        xmlns:controls="clr-namespace:OoiMRR.Controls"
        xmlns:tagTrain="clr-namespace:TagTrain.UI"
        Title="OoiMRR - 文件资源管理器" 
        Height="800" 
        Width="1200"
        MinHeight="600"
        MinWidth="800"
        WindowState="Normal"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        Background="#FFFFFF"
        PreviewKeyDown="MainWindow_PreviewKeyDown"
        Closing="Window_Closing"
        SizeChanged="Window_SizeChanged"
        LocationChanged="Window_LocationChanged">
    
    <Window.Resources>
        <local:TimeUnitConverter x:Key="TimeUnitConverter"/>
    </Window.Resources>
    
    <!-- 主容器：包含标题栏和窗口内容 -->
    <Grid Name="MainContainer">
        <!-- 窗口内容容器 -->
    <Grid Name="RootGrid" Background="#FFFFFF" Margin="0,0,0,0">
        <!-- 左中右3列布局 -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="ColLeft" Width="220" MinWidth="220"/>
            <ColumnDefinition Width="6"/>
            <ColumnDefinition x:Name="ColCenter" Width="*" MinWidth="250"/>
            <ColumnDefinition Width="6"/>
            <ColumnDefinition x:Name="ColRight" Width="360" MinWidth="360"/>
        </Grid.ColumnDefinitions>
        
        <!-- 布局：标题栏行 + 标签页行 + 内容行 -->
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- 标题栏：包含列1导航按钮和列2操作按钮，支持拖拽 -->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="5"
                Background="#F8F9FA" BorderBrush="#E9ECEF" BorderThickness="0,0,0,1"
                MouseDown="TitleBar_MouseDown"
                Panel.ZIndex="1000">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- 列1：导航按钮和操作按钮（左侧） -->
                <Grid Name="NavButtonsContainer" Grid.Column="0" VerticalAlignment="Center" Margin="8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Name="NavButtonsColumn" Width="220"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 导航按钮区域：3个按钮平均分配列1宽度 -->
                    <UniformGrid Grid.Column="0" Rows="1" Columns="3">
                        <Button Name="NavPathBtn" Content="路径" Click="NavPathBtn_Click" Margin="2,0" Height="36"
                                Style="{StaticResource ModernButtonStyle}"/>
                        <Button Name="NavLibraryBtn" Content="库" Click="NavLibraryBtn_Click" Margin="2,0" Height="36"
                                Style="{StaticResource ModernButtonStyle}"/>
                        <Button Name="NavTagBtn" Content="标签" Click="NavTagBtn_Click" Margin="2,0" Height="36"
                                Style="{StaticResource ModernButtonStyle}"/>
                    </UniformGrid>
                    
                    <!-- 分隔符 -->
                    <Separator Name="TitleBarSeparator" Grid.Column="1" Margin="12,0" VerticalAlignment="Center" Height="24" Width="1"/>
                    
                    <!-- 操作按钮栏 -->
                    <controls:TitleActionBar Grid.Column="2"
                                             x:Name="TitleActionBar"
                                             VerticalAlignment="Center"
                                             Margin="8,0,0,0"
                                             Mode="Path"
                                             NewFolderClicked="NewFolder_Click"
                                             NewFileClicked="NewFile_Click"
                                             CopyClicked="Copy_Click"
                                             PasteClicked="Paste_Click"
                                             DeleteClicked="Delete_Click"
                                             RefreshClicked="Refresh_Click"
                                             NewTagClicked="NewTag_Click"
                                             ManageTagsClicked="ManageTags_Click"/>
                </Grid>
                
            </Grid>
        </Border>

        <!-- ========== 标签页管理器 ========== -->
        <controls:TabManagerControl Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5"
                                    x:Name="TabManager" />

        <!-- 垂直分割器（从Row 2开始，跨越2行：Row 2和Row 3） -->
        <GridSplitter Grid.Row="2" Grid.Column="1" Grid.RowSpan="2"
                      Style="{StaticResource VerticalGridSplitterStyle}"
                      ShowsPreview="True"
                      DragCompleted="GridSplitter_DragCompleted"/>
        <GridSplitter Grid.Row="2" Grid.Column="3" Grid.RowSpan="2"
                      Style="{StaticResource VerticalGridSplitterStyle}"
                      ShowsPreview="True"
                      DragCompleted="GridSplitter_DragCompleted"/>

        <!-- ========== 列1：导航区（独立控件） ========== -->
        <controls:NavigationPanelControl Grid.Row="2" Grid.Column="0" Grid.RowSpan="2" x:Name="NavigationPanelControl"/>

        <!-- ========== 列2：文件显示区 ========== -->
        <controls:FileBrowserControl x:Name="FileBrowser"
                                     Grid.Column="2" 
                                     Grid.Row="1" 
                                     Grid.RowSpan="3"
                                     HorizontalAlignment="Stretch" 
                                     VerticalAlignment="Stretch"
                                     Margin="0,0,0,0"/>

        <!-- ========== 列3：预览/备注区 ========== -->
        <local:RightPanelControl Grid.Row="0" Grid.Column="4" Grid.RowSpan="4"
                                 x:Name="RightPanel"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch"/>

        <!-- 设置覆盖层：覆盖列2和列3 -->
        <Grid Name="SettingsOverlay"
              Grid.Row="2" Grid.RowSpan="2"
              Grid.Column="2" Grid.ColumnSpan="3"
              Background="#F0F0F0"
              Panel.ZIndex="5000"
              Visibility="Collapsed">
            <controls:SettingsPanelControl x:Name="SettingsPanel"/>
        </Grid>
        </Grid>
        
        <!-- 右上角窗口控制按钮：独立的Grid确保可交互，不拦截其他事件 -->
        <Grid Name="WindowControlButtonsContainer" 
              Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="5"
              HorizontalAlignment="Right" VerticalAlignment="Top"
              Background="Transparent"
              Width="200" Height="36"
              Panel.ZIndex="10000"
              Margin="0,0,0,0"
              PreviewMouseDown="WindowControlButtonsContainer_PreviewMouseDown">
            <!-- 按钮区域：固定在右上角 -->
            <StackPanel Orientation="Horizontal"
                       HorizontalAlignment="Right" VerticalAlignment="Center"
                       Background="Transparent"
                       Height="36">
                <!-- 设置按钮 -->
                <Button x:Name="TitleBarSettingsButton" Content="&#xE713;" 
                        Width="40" Height="36" 
                        Click="Settings_Click" 
                        ToolTip="设置" FontSize="16" FontFamily="Segoe MDL2 Assets"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E5E5E5"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#CCCCCC"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <!-- 关于按钮 -->
                <Button x:Name="TitleBarAboutButton" Content="&#xE946;" 
                        Width="40" Height="36" 
                        Click="About_Click" 
                        ToolTip="关于" FontSize="16" FontFamily="Segoe MDL2 Assets"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E5E5E5"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#CCCCCC"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <!-- 最小化按钮 -->
                <Button x:Name="TitleBarMinimizeButton" Content="&#xE921;" 
                        Width="40" Height="36" 
                        Click="WindowMinimize_Click" 
                        ToolTip="最小化" FontSize="16" FontFamily="Segoe MDL2 Assets"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E5E5E5"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#CCCCCC"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="TitleBarMaxRestoreButton" Content="&#xE922;" 
                        Width="40" Height="36" 
                        Click="WindowMaximize_Click" 
                        ToolTip="最大化" FontSize="16" FontFamily="Segoe MDL2 Assets"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E5E5E5"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#CCCCCC"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="TitleBarCloseButton" Content="&#xE8BB;" 
                        Width="40" Height="36" 
                        Click="WindowClose_Click" 
                        ToolTip="关闭" FontSize="16" FontFamily="Segoe MDL2 Assets"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E81123"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#C50E1F"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
