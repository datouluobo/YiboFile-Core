<Window x:Class="OoiMRR.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OoiMRR"
        xmlns:controls="clr-namespace:OoiMRR.Controls"
        Title="OoiMRR - 文件资源管理器" 
        Height="800" 
        Width="1200"
        MinHeight="600"
        MinWidth="800"
        WindowState="Normal"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        Background="#FFFFFF"
        PreviewKeyDown="MainWindow_PreviewKeyDown">
    
    <Window.Resources>
        <local:TimeUnitConverter x:Key="TimeUnitConverter"/>
    </Window.Resources>
    
    <!-- 主容器：包含标题栏和窗口内容 -->
    <Grid Name="MainContainer">
        <!-- 窗口内容容器 -->
    <Grid Name="RootGrid" Background="#FFFFFF" Margin="0,0,0,0">
        <!-- 左中右3列布局 -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="ColLeft" Width="300" MinWidth="220"/>
            <ColumnDefinition Width="6"/>
            <ColumnDefinition x:Name="ColCenter" Width="*" MinWidth="250"/>
            <ColumnDefinition Width="6"/>
            <ColumnDefinition x:Name="ColRight" Width="*" MinWidth="360"/>
        </Grid.ColumnDefinitions>
        
        <!-- 布局：标题栏行 + 内容行 -->
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- 标题栏：包含列1导航按钮和列2操作按钮，支持拖拽 -->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="5"
                Background="#F8F9FA" BorderBrush="#E9ECEF" BorderThickness="0,0,0,1"
                MouseDown="TitleBar_MouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- 列1：导航按钮和操作按钮（左侧） -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                    <!-- 固定导航按钮（4个） -->
                    <Button Name="NavPathBtn" Content="路径" Click="NavPathBtn_Click" Margin="2" MinWidth="60">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=NavPathContent, Path=Visibility}" Value="Visible">
                                        <Setter Property="Background" Value="{DynamicResource HighlightBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource HighlightBorderBrush}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Name="NavLibraryBtn" Content="库" Click="NavLibraryBtn_Click" Margin="2" MinWidth="60">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=NavLibraryContent, Path=Visibility}" Value="Visible">
                                        <Setter Property="Background" Value="{DynamicResource HighlightBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource HighlightBorderBrush}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Name="NavTagBtn" Content="标签" Click="NavTagBtn_Click" Margin="2" MinWidth="60">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=NavTagContent, Path=Visibility}" Value="Visible">
                                        <Setter Property="Background" Value="{DynamicResource HighlightBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource HighlightBorderBrush}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    
                    <!-- 分隔符 -->
                    <Separator Name="TitleBarSeparator" Margin="12,0" VerticalAlignment="Center" Height="20"/>
                    
                    <!-- 动态操作按钮区域（可拖动排序） -->
                    <StackPanel Name="ActionButtonsContainer" Orientation="Horizontal" VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- 列2：占位（原操作按钮区域已移除） -->
                <Grid Grid.Column="1" Name="ActionButtonsGrid" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="8,0">
                    <!-- 隐藏的按钮定义（用于从代码中读取） -->
                    <StackPanel Name="PathActionButtons" Orientation="Horizontal" Visibility="Collapsed">
                        <Button Content="📁 新建文件夹" Click="NewFolder_Click" Margin="0,0,4,0"/>
                        <Button Content="📄 新建文件" Click="NewFile_Click" Margin="0,0,4,0"/>
                        <Separator Margin="16,0"/>
                        <Button Content="复制" Click="Copy_Click" Margin="0,0,4,0"/>
                        <Button Content="粘贴" Click="Paste_Click" Margin="0,0,4,0"/>
                        <Button Content="删除" Click="Delete_Click" Margin="0,0,4,0"/>
                        <Separator Margin="16,0"/>
                        <Button Content="⭐ 添加收藏" Click="AddFavorite_Click" Margin="0,0,4,0"/>
                        <Button Content="🏷️ 添加标签" Click="AddTagToFile_Click" Margin="0,0,4,0"/>
                        <Button Content="🔄 刷新" Click="Refresh_Click"/>
                    </StackPanel>
                    
                    <StackPanel Name="LibraryActionButtons" Orientation="Horizontal" Visibility="Collapsed">
                        <Button Content="📁 新建文件夹" Click="NewFolder_Click" Margin="0,0,4,0"/>
                        <Button Content="📄 新建文件" Click="NewFile_Click" Margin="0,0,4,0"/>
                        <Separator Margin="16,0"/>
                        <Button Content="📚 新建库" Click="AddLibrary_Click" Margin="0,0,4,0"/>
                        <Button Content="📂 添加到库" Click="AddFileToLibrary_Click" Margin="0,0,4,0"/>
                        <Button Content="⚙️ 管理库" Click="ManageLibraries_Click" Margin="0,0,4,0"/>
                        <Separator Margin="16,0"/>
                        <Button Content="复制" Click="Copy_Click" Margin="0,0,4,0"/>
                        <Button Content="粘贴" Click="Paste_Click" Margin="0,0,4,0"/>
                        <Button Content="删除" Click="Delete_Click" Margin="0,0,4,0"/>
                        <Separator Margin="16,0"/>
                        <Button Content="⭐ 添加收藏" Click="AddFavorite_Click" Margin="0,0,4,0"/>
                        <Button Content="🏷️ 添加标签" Click="AddTagToFile_Click" Margin="0,0,4,0"/>
                        <Button Content="🔄 刷新" Click="Refresh_Click"/>
                    </StackPanel>
                    
                    <StackPanel Name="TagActionButtons" Orientation="Horizontal" Visibility="Collapsed">
                        <Button Content="🏷️ 新建标签" Click="NewTag_Click" Margin="0,0,4,0"/>
                        <Button Content="🛠️ 管理标签" Click="ManageTags_Click" Margin="0,0,4,0"/>
                        <Separator Margin="16,0"/>
                        <Button Content="📦 批量添加" Click="BatchAddTags_Click" Margin="0,0,4,0"/>
                        <Button Content="📊 标签统计" Click="TagStatistics_Click"/>
                    </StackPanel>
                </Grid>
                
            </Grid>
        </Border>
        
        <!-- 垂直分割器（从Row 1开始，跨越2行：Row 1和Row 2） -->
        <GridSplitter Grid.Row="1" Grid.Column="1" Grid.RowSpan="2" 
                      Style="{StaticResource VerticalGridSplitterStyle}" DragDelta="GridSplitter_DragDelta"/>
        <GridSplitter Grid.Row="1" Grid.Column="3" Grid.RowSpan="2" 
                      Style="{StaticResource VerticalGridSplitterStyle}"/>
        
        <!-- ========== 列1：导航区 ========== -->
        <!-- 导航按钮已移到标题栏，直接显示内容区域 -->
        <Grid Grid.Row="1" Grid.Column="0" Grid.RowSpan="2" Background="#FFFFFF">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <Grid Name="NavContentGrid" Grid.Row="0">
                <!-- 路径导航内容 -->
                <Grid Name="NavPathContent" Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 子行0：面包屑导航（完整路径，支持多行） -->
                    <Border Grid.Row="0" Background="#FFFFFF" Margin="0,0,0,8">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="4" MaxHeight="120">
                            <WrapPanel Name="BreadcrumbPanel" Orientation="Horizontal"/>
                        </ScrollViewer>
                    </Border>
                    
                    <!-- 驱动器列表 -->
                    <GroupBox Grid.Row="1" Header="驱动器" Margin="0,0,0,8" Style="{StaticResource ModernGroupBoxStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ListBox Name="DrivesListBox" 
                                     Margin="2"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     SelectionMode="Single"
                                     PreviewMouseDown="DrivesListBox_PreviewMouseDown"
                                     ItemContainerStyle="{StaticResource NavListBoxItemStyle}"/>
                        </ScrollViewer>
                    </GroupBox>
                    
                    <!-- 快速访问 -->
                    <GroupBox Grid.Row="2" Header="快速访问" Margin="0,0,0,8" Style="{StaticResource ModernGroupBoxStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ListBox Name="QuickAccessListBox" 
                                     Margin="2"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     SelectionMode="Single"
                                     PreviewMouseDown="QuickAccessListBox_PreviewMouseDown"
                                     ItemContainerStyle="{StaticResource NavListBoxItemStyle}"/>
                        </ScrollViewer>
                    </GroupBox>
                    
                    <!-- 收藏 -->
                    <GroupBox Grid.Row="3" Header="收藏" Style="{StaticResource ModernGroupBoxStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ListBox Name="FavoritesListBox" 
                                     Margin="2"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     SelectionMode="Single"
                                     PreviewMouseDown="FavoritesListBox_PreviewMouseDown"
                                     ItemContainerStyle="{StaticResource NavListBoxItemStyle}"/>
                        </ScrollViewer>
                    </GroupBox>
                </Grid>
                
                <!-- 库导航内容 -->
                <Grid Name="NavLibraryContent" Margin="8" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 库功能按钮已移动到标题栏，此处不再显示 -->
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ListBox Name="LibrariesListBox" 
                                 Margin="2"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 SelectionMode="Single"
                                 SelectionChanged="LibrariesListBox_SelectionChanged"
                                 DisplayMemberPath="Name"
                                 ContextMenuOpening="LibrariesListBox_ContextMenuOpening"
                                 AllowDrop="True"
                                 ItemContainerStyle="{StaticResource NavListBoxItemStyle}">
                            <ListBox.ContextMenu>
                                <ContextMenu Name="LibraryContextMenu">
                                    <MenuItem Header="重命名" Click="LibraryRename_Click" Name="LibraryRenameMenuItem"/>
                                    <MenuItem Header="删除库" Click="LibraryDelete_Click" Name="LibraryDeleteMenuItem"/>
                                    <Separator/>
                                    <MenuItem Header="管理库位置" Click="LibraryManage_Click" Name="LibraryManageMenuItem"/>
                                    <MenuItem Header="在资源管理器中打开" Click="LibraryOpenInExplorer_Click" Name="LibraryOpenInExplorerMenuItem"/>
                                    <Separator/>
                                    <MenuItem Header="刷新库列表" Click="LibraryRefresh_Click"/>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                        </ListBox>
                    </ScrollViewer>
                </Grid>
                
                <!-- 标签导航内容：集成TagTrain训练面板（外层不滚动，标签列表自身滚动） -->
                <ScrollViewer Name="NavTagContent" Margin="8" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- AI预测结果 -->
                        <GroupBox Grid.Row="0" Margin="0,1,0,3" Padding="2" Style="{StaticResource ModernGroupBoxStyle}">
                            <GroupBox.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🤖 AI预测结果" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Ellipse Name="TagTrainModelStatusIndicator" Width="12" Height="12" 
                                            VerticalAlignment="Center" Margin="0,0,5,0">
                                        <Ellipse.Fill>
                                            <SolidColorBrush Color="Gray"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <TextBlock Name="TagTrainModelStatusText" Text="检查中..." FontSize="11" 
                                              VerticalAlignment="Center" Foreground="Gray"/>
                                </StackPanel>
                            </GroupBox.Header>
                            <!-- 预测区域固定两行标签高度，避免有无预测时布局跳动 -->
                            <WrapPanel Name="TagTrainPredictionPanel" Orientation="Horizontal"
                                       Height="64" MinHeight="64" MaxHeight="64"
                                       VerticalAlignment="Top">
                                <TextBlock Text="暂无预测结果" Foreground="Gray" FontStyle="Italic" 
                                          Name="TagTrainNoPredictionText" Visibility="Visible"/>
                            </WrapPanel>
                        </GroupBox>

                        <!-- 已标注标签列表 -->
                        <GroupBox Grid.Row="1" Margin="0,1,0,3" Padding="2" Style="{StaticResource ModernGroupBoxStyle}">
                            <GroupBox.Header>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="📋 已有标签（点击选择，右键删除）" VerticalAlignment="Center"/>
                                    <ComboBox Name="TagTrainTagSortComboBox" Grid.Column="1" Width="120" Height="25" 
                                             SelectionChanged="TagTrainTagSortComboBox_SelectionChanged"
                                             FontSize="11" VerticalContentAlignment="Center">
                                        <ComboBoxItem Content="按使用次数" Tag="Count"/>
                                        <ComboBoxItem Content="按字母顺序" Tag="Name" IsSelected="True"/>
                                        <ComboBoxItem Content="按预测度" Tag="Prediction"/>
                                    </ComboBox>
                                </Grid>
                            </GroupBox.Header>
                            <ScrollViewer x:Name="TagTrainExistingTagsScrollViewer"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalAlignment="Stretch">
                                <WrapPanel Name="TagTrainExistingTagsPanel" Orientation="Horizontal"
                                           VerticalAlignment="Top"
                                           SizeChanged="TagTrainExistingTagsPanel_SizeChanged"/>
                            </ScrollViewer>
                        </GroupBox>

                        <!-- 标签输入区域 -->
                        <GroupBox Grid.Row="2" Header="🏷️ 输入标签（按Tab键分隔）" Margin="0,0,0,10" Padding="8" Style="{StaticResource ModernGroupBoxStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 标签输入区域 -->
                                <WrapPanel Grid.Row="0" Name="TagTrainTagInputPanel" Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Name="TagTrainTagInputBorder" 
                                           MinWidth="150" Width="250" Height="30"
                                           Style="{StaticResource TagInputBorderStyle}">
                                        <Grid>
                                            <TextBox Name="TagTrainTagInputTextBox" 
                                                    FontSize="13"
                                                    VerticalContentAlignment="Center"
                                                    Padding="7,5"
                                                    BorderThickness="0"
                                                    Background="Transparent"
                                                    TextChanged="TagTrainTagInputTextBox_TextChanged"
                                                    KeyDown="TagTrainTagInputTextBox_KeyDown"
                                                    PreviewKeyDown="TagTrainTagInputTextBox_PreviewKeyDown"
                                                    GotFocus="TagTrainTagInputTextBox_GotFocus"
                                                    LostFocus="TagTrainTagInputTextBox_LostFocus"
                                                    ToolTip="输入标签后按Tab键添加，按Tab键可自动补完"/>
                                            <Popup Name="TagTrainTagAutocompletePopup" 
                                                  Placement="Bottom"
                                                  StaysOpen="True"
                                                  AllowsTransparency="True"
                                                  PopupAnimation="Fade"
                                                  MaxHeight="200"
                                                  MinWidth="150"
                                                  HorizontalOffset="0"
                                                  VerticalOffset="2"
                                                  Focusable="False">
                                                <Border BorderBrush="#CCCCCC" BorderThickness="1" 
                                                       Background="White" CornerRadius="4"
                                                       MinWidth="150">
                                                    <ListBox Name="TagTrainTagAutocompleteListBox"
                                                            MaxHeight="200"
                                                            SelectionMode="Single"
                                                            MouseDoubleClick="TagTrainTagAutocompleteListBox_MouseDoubleClick"
                                                            KeyDown="TagTrainTagAutocompleteListBox_KeyDown"
                                                            Background="White"
                                                            BorderThickness="0"
                                                            MinWidth="150">
                                                        <ListBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding}" 
                                                                          Padding="8,4"
                                                                          FontSize="12"/>
                                                            </DataTemplate>
                                                        </ListBox.ItemTemplate>
                                                        <ListBox.ItemContainerStyle>
                                                            <Style TargetType="ListBoxItem">
                                                                <Setter Property="Padding" Value="0"/>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="{DynamicResource HighlightHoverBrush}"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsSelected" Value="True">
                                                                        <Setter Property="Background" Value="{DynamicResource HighlightBrush}"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ListBox.ItemContainerStyle>
                                                    </ListBox>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </Border>
                                </WrapPanel>

                                <WrapPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="✅ 确认标签" Click="TagTrainConfirmTag_Click" 
                                           MinWidth="100" Height="35" FontSize="14" Margin="0,0,10,0"
                                           IsDefault="True"/>
                                    <Button Content="🤖 确认AI预测" Click="TagTrainConfirmAIPrediction_Click" 
                                           MinWidth="110" Height="35" FontSize="14" Margin="0,0,10,0"
                                           Name="TagTrainConfirmAIPredictionBtn"
                                           ToolTip="确认AI预测结果，自动保存为训练数据"/>
                                    <Button Content="⏭️ 跳过" Click="TagTrainSkip_Click" MinWidth="80" Height="35" FontSize="14"/>
                                </WrapPanel>
                            </Grid>
                        </GroupBox>

                        <!-- 操作按钮区域 -->
                        <WrapPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Name="TagClickModeBtn"
                                   Content="👁 浏览"
                                   Click="TagClickModeBtn_Click"
                                   Height="35" FontSize="13" Margin="0,0,8,8" MinWidth="90"
                                   ToolTip="切换标签点击行为：浏览(显示文件) / 编辑(给所选文件加/移除该标签)"/>
                            <Button Content="▶️ 开始训练" Click="TagTrainStartTraining_Click" 
                                   Name="TagTrainStartTrainingBtn" Height="35" FontSize="13" Margin="0,0,8,8" MinWidth="100"/>
                            <Button Content="⏸️ 暂停" Click="TagTrainPause_Click" Name="TagTrainPauseBtn" 
                                   Height="35" FontSize="13" IsEnabled="False" Margin="0,0,8,8" MinWidth="80"
                                   Visibility="Collapsed"/>
                            <Button Content="🔄 重新训练模型" Click="TagTrainRetrainModel_Click" 
                                   Name="TagTrainRetrainModelBtn" Height="35" FontSize="13" Margin="0,0,8,8" MinWidth="120"/>
                            <Button Content="❌ 取消训练" Click="TagTrainCancelTraining_Click" 
                                   Name="TagTrainCancelTrainingBtn" Height="35" FontSize="13" IsEnabled="False" Margin="0,0,8,8" MinWidth="100"
                                   Visibility="Collapsed"/>
                            <Button Content="📦 批量操作" Click="TagTrainBatchOperation_Click" 
                                   Name="TagTrainBatchOperationBtn" Height="35" FontSize="13" Margin="0,0,8,8" MinWidth="100"/>
                            <Button Content="📈 训练情况" Click="TagTrainTrainingStatus_Click" 
                                   Name="TagTrainTrainingStatusBtn" Height="35" FontSize="13" Margin="0,0,8,8" MinWidth="100"/>
                            <Button Content="🧹 清理重复标签" Click="TagTrainConsolidateTags_Click" 
                                   Name="TagTrainConsolidateTagsBtn" Height="35" FontSize="13" Margin="0,0,8,8" MinWidth="120"/>
                            <Button Content="⚙️ 设置" Click="TagTrainConfig_Click" 
                                   Height="35" FontSize="13" Margin="0,0,0,8" MinWidth="80"/>
                        </WrapPanel>

                        <!-- 训练进度显示 -->
                        <Grid Grid.Row="4" Margin="0,0,0,10" Visibility="Collapsed" Name="TagTrainTrainingProgressGrid">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Name="TagTrainTrainingStageText" Text="" 
                                      FontSize="12" FontWeight="Bold" Margin="0,0,0,5"/>
                            <ProgressBar Grid.Row="1" Name="TagTrainTrainingProgressBar" 
                                        Height="20" Minimum="0" Maximum="100" Value="0"/>
                            <TextBlock Grid.Row="2" Name="TagTrainTrainingProgressText" Text="" 
                                      FontSize="11" Foreground="Gray" Margin="0,5,0,0"/>
                        </Grid>

                        <!-- 状态栏 -->
                        <TextBlock Grid.Row="5" Name="TagTrainStatusText" Text="就绪" 
                                  VerticalAlignment="Center" Foreground="Gray" FontSize="12" 
                                  TextWrapping="Wrap" Margin="0,0,0,8"/>
                    </Grid>
                </ScrollViewer>
                
            </Grid>
            
            <!-- 系统级按钮 -->
            <Border Grid.Row="1" Background="#F8F9FA" BorderBrush="#E9ECEF" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="8,8">
                    <Button Content="⚙️" Click="Settings_Click" Width="32" Height="32" 
                            Style="{StaticResource ModernButtonStyle}" ToolTip="设置" Margin="4,0"/>
                    <Button Content="ℹ️" Click="About_Click" Width="32" Height="32" 
                            Style="{StaticResource ModernButtonStyle}" ToolTip="关于" Margin="4,0"/>
                    <Button Content="🧪" Click="RunVisualTests_Click" Width="32" Height="32" 
                            Style="{StaticResource ModernButtonStyle}" ToolTip="视觉测试" Margin="4,0"/>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- ========== 列2：文件显示区 ========== -->
        <controls:FileBrowserControl Grid.Row="1" Grid.Column="2" Grid.RowSpan="2"
                                     x:Name="FileBrowser"
                                     FilesSelectionChanged="FileBrowser_FilesSelectionChanged"
                                     FilesMouseDoubleClick="FileBrowser_FilesMouseDoubleClick"
                                     FilesPreviewMouseDoubleClick="FileBrowser_FilesPreviewMouseDoubleClick"
                                     FilesPreviewKeyDown="FileBrowser_FilesPreviewKeyDown"
                                     FilesPreviewMouseLeftButtonDown="FileBrowser_FilesPreviewMouseLeftButtonDown"
                                     FilesMouseLeftButtonUp="FileBrowser_FilesMouseLeftButtonUp"
                                     FilesPreviewMouseDown="FileBrowser_FilesPreviewMouseDown"
                                     GridViewColumnHeaderClick="FileBrowser_GridViewColumnHeaderClick"
                                     FilesSizeChanged="FileBrowser_FilesSizeChanged"
                                     FilesPreviewMouseDoubleClickForBlank="FileBrowser_FilesPreviewMouseDoubleClickForBlank"
                                     PathChanged="FileBrowser_PathChanged"
                                     BreadcrumbClicked="FileBrowser_BreadcrumbClicked"/>

        <!-- ========== 列3：预览/备注区 ========== -->
        <local:RightPanelControl Grid.Row="0" Grid.Column="4" Grid.RowSpan="4"
                                 x:Name="RightPanel"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch"/>
        </Grid>
        
        <!-- 右上角窗口控制按钮：独立的Grid确保可交互，不拦截其他事件 -->
        <Grid Name="WindowControlButtonsContainer" 
              HorizontalAlignment="Right" VerticalAlignment="Top"
              Background="Transparent"
              Width="102" Height="36"
              Panel.ZIndex="10000"
              Margin="0,0,0,0">
            <!-- 按钮区域：固定在右上角 -->
            <StackPanel Orientation="Horizontal"
                       HorizontalAlignment="Right" VerticalAlignment="Top"
                       Background="Transparent">
                <Button x:Name="TitleBarMinimizeButton" Content="&#xE921;" 
                        Width="30" Height="30" 
                        Click="WindowMinimize_Click" 
                        ToolTip="最小化" FontSize="16" FontFamily="Segoe MDL2 Assets"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E0E0E0"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#C0C0C0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="TitleBarMaxRestoreButton" Content="&#xE922;" 
                        Width="30" Height="30" 
                        Click="WindowMaximize_Click" 
                        ToolTip="最大化" FontSize="16" FontFamily="Segoe MDL2 Assets" 
                        Margin="4,0,0,0"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E0E0E0"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#C0C0C0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="TitleBarCloseButton" Content="&#xE8BB;" 
                        Width="30" Height="30" 
                        Click="WindowClose_Click" 
                        ToolTip="关闭" FontSize="16" FontFamily="Segoe MDL2 Assets" 
                        Margin="4,0,0,0"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E81123"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#C50E1F"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
