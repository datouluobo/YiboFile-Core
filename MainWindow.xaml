<Window x:Class="OoiMRR.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OoiMRR"
        Title="OoiMRR - 文件资源管理器" 
        Height="800" 
        Width="1200"
        MinHeight="600"
        MinWidth="800"
        WindowState="Normal"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        Background="#FFFFFF">
    
    <Window.Resources>
        <local:TimeUnitConverter x:Key="TimeUnitConverter"/>
    </Window.Resources>
    
    <!-- 主容器：包含标题栏和窗口内容 -->
    <Grid Name="MainContainer">
        <!-- 窗口内容容器 -->
    <Grid Name="RootGrid" Background="#FFFFFF" Margin="0,0,0,0">
        <!-- 左中右3列布局 -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="ColLeft" Width="300" MinWidth="220"/>
            <ColumnDefinition Width="6"/>
            <ColumnDefinition x:Name="ColCenter" Width="*" MinWidth="250"/>
            <ColumnDefinition Width="6"/>
            <ColumnDefinition x:Name="ColRight" Width="*" MinWidth="360"/>
        </Grid.ColumnDefinitions>
        
        <!-- 布局：标题栏行 + 内容行 -->
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- 标题栏：包含列1导航按钮和列2操作按钮，支持拖拽 -->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="5"
                Background="#F8F9FA" BorderBrush="#E9ECEF" BorderThickness="0,0,0,1"
                MouseDown="TitleBar_MouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- 列1：导航按钮（左侧） -->
                <Grid Grid.Column="0" VerticalAlignment="Center" Margin="8,0,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" Name="NavPathBtn" Content="路径" Click="NavPathBtn_Click" Margin="2" MinWidth="60"/>
                    <Button Grid.Column="1" Name="NavLibraryBtn" Content="库" Click="NavLibraryBtn_Click" Margin="2" MinWidth="60"/>
                    <Button Grid.Column="2" Name="NavTagBtn" Content="标签" Click="NavTagBtn_Click" Margin="2" MinWidth="60"/>
                    <Button Grid.Column="3" Name="NavSearchBtn" Content="搜索" Click="NavSearchBtn_Click" Margin="2" MinWidth="60"/>
                </Grid>
                
                <!-- 列2：操作按钮（中间，在标题栏中，视觉上对应列2区域，动态居中显示） -->
                <Grid Grid.Column="1" Name="ActionButtonsGrid" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="8,0">
                    <!-- 路径模式按钮 -->
                    <StackPanel Name="PathActionButtons" Orientation="Horizontal" Margin="0,0">
                        <Button Content="📁 新建文件夹" Click="NewFolder_Click" Margin="0,0,4,0"/>
                        <Button Content="📄 新建文件" Click="NewFile_Click" Margin="0,0,4,0"/>
                        <Separator Margin="8,0"/>
                        <Button Content="复制" Click="Copy_Click" Margin="0,0,4,0"/>
                        <Button Content="粘贴" Click="Paste_Click" Margin="0,0,4,0"/>
                        <Button Content="删除" Click="Delete_Click" Margin="0,0,4,0"/>
                        <Separator Margin="8,0"/>
                        <Button Content="🏷️ 添加标签" Click="AddTagToFile_Click" Margin="0,0,4,0"/>
                        <Button Content="🔄 刷新" Click="Refresh_Click"/>
                    </StackPanel>
                    
                    <!-- 库模式按钮 -->
                    <StackPanel Name="LibraryActionButtons" Orientation="Horizontal" Margin="0,0" Visibility="Collapsed">
                        <Button Content="📚 新建库" Click="AddLibrary_Click" Margin="0,0,4,0"/>
                        <Button Content="📂 添加文件到库" Click="AddFileToLibrary_Click" Margin="0,0,4,0"/>
                        <Button Content="📑 编辑库" Click="EditLibrary_Click" Margin="0,0,4,0"/>
                        <Separator Margin="8,0"/>
                        <Button Content="🏷️ 添加标签" Click="AddTagToFile_Click" Margin="0,0,4,0"/>
                        <Button Content="🔄 刷新" Click="Refresh_Click"/>
                    </StackPanel>
                    
                    <!-- 标签模式按钮 -->
                    <StackPanel Name="TagActionButtons" Orientation="Horizontal" Margin="0,0" Visibility="Collapsed">
                        <Button Content="➕ 新建标签" Click="NewTag_Click" Margin="0,0,4,0"/>
                        <Button Content="✏️ 编辑标签" Click="ManageTags_Click" Margin="0,0,4,0"/>
                        <Separator Margin="8,0"/>
                        <Button Content="📦 批量添加标签" Click="BatchAddTags_Click" Margin="0,0,4,0"/>
                        <Button Content="📊 标签统计" Click="TagStatistics_Click"/>
                    </StackPanel>
                    
                    <!-- 搜索模式按钮 -->
                    <StackPanel Name="SearchActionButtons" Orientation="Horizontal" Margin="0,0" Visibility="Collapsed">
                        <Button Content="🔍 高级搜索" Click="AdvancedSearch_Click" Margin="0,0,4,0"/>
                        <Button Content="💾 保存搜索" Click="SaveSearch_Click" Margin="0,0,4,0"/>
                        <Separator Margin="8,0"/>
                        <Button Content="📜 搜索历史" Click="SearchHistory_Click" Margin="0,0,4,0"/>
                        <Button Content="🗑️ 清除历史" Click="ClearSearchHistory_Click"/>
                    </StackPanel>
                </Grid>
                
            </Grid>
        </Border>
        
        <!-- 垂直分割器（从Row 1开始，跨越2行：Row 1和Row 2） -->
        <GridSplitter Grid.Row="1" Grid.Column="1" Grid.RowSpan="2" 
                      Style="{StaticResource VerticalGridSplitterStyle}"/>
        <GridSplitter Grid.Row="1" Grid.Column="3" Grid.RowSpan="2" 
                      Style="{StaticResource VerticalGridSplitterStyle}"/>
        
        <!-- ========== 列1：导航区 ========== -->
        <!-- 导航按钮已移到标题栏，直接显示内容区域 -->
        <Grid Grid.Row="1" Grid.Column="0" Grid.RowSpan="2" Background="#FFFFFF">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <Grid Name="NavContentGrid" Grid.Row="0">
                <!-- 路径导航内容 -->
                <Grid Name="NavPathContent" Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 子行0：面包屑导航（完整路径，支持多行） -->
                    <Border Grid.Row="0" Background="#FFFFFF" Margin="0,0,0,8">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="4" MaxHeight="120">
                            <WrapPanel Name="BreadcrumbPanel" Orientation="Horizontal"/>
                        </ScrollViewer>
                    </Border>

                    <!-- 子行1：导航按钮（← → ↑） -->
                    <Border Grid.Row="1" Background="#F8F9FA" BorderBrush="#E9ECEF" BorderThickness="1" CornerRadius="4" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="8,4">
                            <Button Content="←" Width="28" Height="28" Click="NavigateBack_Click" 
                                    Style="{StaticResource ModernButtonStyle}" Margin="0,0,6,0"/>
                            <Button Content="→" Width="28" Height="28" Click="NavigateForward_Click" 
                                    Style="{StaticResource ModernButtonStyle}" Margin="0,0,6,0"/>
                            <Button Content="↑" Width="28" Height="28" Click="NavigateUp_Click" 
                                    Style="{StaticResource ModernButtonStyle}"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- 驱动器列表 -->
                    <GroupBox Grid.Row="2" Header="驱动器" Margin="0,0,0,8" Style="{StaticResource ModernGroupBoxStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="150">
                            <StackPanel Name="DrivesPanel" Margin="2"/>
                        </ScrollViewer>
                    </GroupBox>
                    
                    <!-- 快速访问 -->
                    <GroupBox Grid.Row="3" Header="快速访问" Style="{StaticResource ModernGroupBoxStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Name="QuickAccessPanel" Margin="2"/>
                        </ScrollViewer>
                    </GroupBox>
                </Grid>
                
                <!-- 库导航内容 -->
                <Grid Name="NavLibraryContent" Margin="8" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <Button Content="添加库" Click="AddLibrary_Click" Margin="0,0,0,4"/>
                        <Button Content="管理库" Click="ManageLibraries_Click"/>
                    </StackPanel>
                    
                    <ListBox Grid.Row="1" Name="LibrariesListBox" 
                             SelectionChanged="LibrariesListBox_SelectionChanged"/>
                </Grid>
                
                <!-- 标签导航内容 -->
                <Grid Name="NavTagContent" Margin="8" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <Button Content="新建标签" Click="NewTag_Click" Margin="0,0,0,4"/>
                        <Button Content="管理标签" Click="ManageTags_Click"/>
                    </StackPanel>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <WrapPanel Name="TagsPanel" Margin="2"/>
                    </ScrollViewer>
                </Grid>
                
                <!-- 搜索导航内容 -->
                <Grid Name="NavSearchContent" Margin="8" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBox Grid.Column="0" Name="SearchTextBox" 
                                 TextChanged="SearchTextBox_TextChanged"
                                 KeyDown="SearchTextBox_KeyDown"/>
                        <Button Grid.Column="1" Content="搜索" Click="Search_Click" Margin="4,0,0,0"/>
                    </Grid>
                    
                    <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,0,0,8">
                        <CheckBox Name="SearchInNames" Content="文件名" IsChecked="True" Margin="0,0,0,2"/>
                        <CheckBox Name="SearchInTags" Content="标签" IsChecked="True" Margin="0,0,0,2"/>
                        <CheckBox Name="SearchInNotes" Content="备注" IsChecked="True"/>
                    </StackPanel>
                    
                    <ListBox Grid.Row="2" Name="SearchResultsListBox"
                             SelectionChanged="SearchResultsListBox_SelectionChanged"/>
                </Grid>
            </Grid>
            
            <!-- 系统级按钮 -->
            <Border Grid.Row="1" Background="#F8F9FA" BorderBrush="#E9ECEF" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="8,8">
                    <Button Content="⚙️" Click="Settings_Click" Width="32" Height="32" 
                            Style="{StaticResource ModernButtonStyle}" ToolTip="设置" Margin="4,0"/>
                    <Button Content="ℹ️" Click="About_Click" Width="32" Height="32" 
                            Style="{StaticResource ModernButtonStyle}" ToolTip="关于" Margin="4,0"/>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- ========== 列2：文件显示区 ========== -->
        <Grid Grid.Row="1" Grid.Column="2" Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="180" MinHeight="120"/>
            </Grid.RowDefinitions>

            <!-- 操作按钮已在标题栏，此处移除 -->
            
            <!-- 地址栏（可编辑） -->
            <Border Grid.Row="0" Background="#F8F9FA" Margin="0,2,0,4">
            <Grid Margin="8">
                <TextBox Name="AddressTextBox" 
                         TextChanged="AddressTextBox_TextChanged" 
                         KeyDown="AddressTextBox_KeyDown"
                         Style="{StaticResource ModernTextBoxStyle}"/>
            </Grid>
        </Border>
        
        <!-- 文件列表 -->
        <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#E9ECEF" BorderThickness="0,1,0,0">
            <ListView Name="FilesListView" 
                      SelectionChanged="FilesListView_SelectionChanged"
                      MouseDoubleClick="FilesListView_MouseDoubleClick"
                      PreviewKeyDown="FilesListView_PreviewKeyDown"
                      PreviewMouseLeftButtonDown="FilesListView_PreviewMouseLeftButtonDown"
                      MouseLeftButtonUp="FilesListView_MouseLeftButtonUp"
                      Background="#FFFFFF">
                <ListView.View>
                    <GridView x:Name="FilesGridView">
                        <GridViewColumn Width="200" DisplayMemberBinding="{Binding Name}">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="名称" Click="GridViewColumnHeader_Click" Tag="Name"/>
                            </GridViewColumn.Header>
                        </GridViewColumn>
                        <GridViewColumn x:Name="ColSize" Width="100" DisplayMemberBinding="{Binding Size}">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="大小" Click="GridViewColumnHeader_Click" Tag="Size"/>
                            </GridViewColumn.Header>
                        </GridViewColumn>
                        <GridViewColumn x:Name="ColType" Width="100" DisplayMemberBinding="{Binding Type}">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="类型" Click="GridViewColumnHeader_Click" Tag="Type"/>
                            </GridViewColumn.Header>
                        </GridViewColumn>
                        <GridViewColumn Width="150" DisplayMemberBinding="{Binding ModifiedDate}">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="修改日期" Click="GridViewColumnHeader_Click" Tag="ModifiedDate"/>
                            </GridViewColumn.Header>
                        </GridViewColumn>
                        <GridViewColumn Width="50">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="创建" Click="GridViewColumnHeader_Click" Tag="CreatedTime"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Text>
                                            <Binding Path="CreatedTime"/>
                                        </TextBlock.Text>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <!-- 秒 - 绿色 (最新) -->
                                                    <DataTrigger Binding="{Binding CreatedTime, Converter={StaticResource TimeUnitConverter}}" Value="s">
                                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </DataTrigger>
                                                    <!-- 分钟 - 青色 -->
                                                    <DataTrigger Binding="{Binding CreatedTime, Converter={StaticResource TimeUnitConverter}}" Value="m">
                                                        <Setter Property="Foreground" Value="#00BCD4"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                    <!-- 小时 - 蓝色 -->
                                                    <DataTrigger Binding="{Binding CreatedTime, Converter={StaticResource TimeUnitConverter}}" Value="h">
                                                        <Setter Property="Foreground" Value="#2196F3"/>
                                                    </DataTrigger>
                                                    <!-- 天 - 紫色 -->
                                                    <DataTrigger Binding="{Binding CreatedTime, Converter={StaticResource TimeUnitConverter}}" Value="d">
                                                        <Setter Property="Foreground" Value="#9C27B0"/>
                                                    </DataTrigger>
                                                    <!-- 月 - 棕色 -->
                                                    <DataTrigger Binding="{Binding CreatedTime, Converter={StaticResource TimeUnitConverter}}" Value="mo">
                                                        <Setter Property="Foreground" Value="#795548"/>
                                                    </DataTrigger>
                                                    <!-- 年 - 深灰色 -->
                                                    <DataTrigger Binding="{Binding CreatedTime, Converter={StaticResource TimeUnitConverter}}" Value="y">
                                                        <Setter Property="Foreground" Value="#616161"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Width="150" DisplayMemberBinding="{Binding Tags}">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="标签" Click="GridViewColumnHeader_Click" Tag="Tags"/>
                            </GridViewColumn.Header>
                        </GridViewColumn>
                        <GridViewColumn Width="200" DisplayMemberBinding="{Binding Notes}">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="备注" Click="GridViewColumnHeader_Click" Tag="Notes"/>
                            </GridViewColumn.Header>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>
        
        <!-- 水平分割器 -->
        <GridSplitter Grid.Row="2" Style="{StaticResource HorizontalGridSplitterStyle}"
                      HorizontalAlignment="Stretch"/>
        
        <!-- 文件详细信息 -->
        <Border Grid.Row="3" Background="#F8F9FA" BorderBrush="#E9ECEF" BorderThickness="0,1,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8,4">
                <StackPanel Name="FileInfoPanel" Margin="4"/>
            </ScrollViewer>
        </Border>
        </Grid>

        <!-- ========== 列3：预览/备注区 ========== -->
        <local:RightPanelControl Grid.Row="0" Grid.Column="4" Grid.RowSpan="4"
                                 x:Name="RightPanel"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch"/>
        </Grid>
        
        <!-- 右上角窗口控制按钮：独立的Grid确保可交互，不拦截其他事件 -->
        <Grid Name="WindowControlButtonsContainer" 
              HorizontalAlignment="Right" VerticalAlignment="Top"
              Background="Transparent"
              Width="102" Height="36"
              Panel.ZIndex="10000"
              Margin="0,0,0,0">
            <!-- 按钮区域：固定在右上角 -->
            <StackPanel Orientation="Horizontal"
                       HorizontalAlignment="Right" VerticalAlignment="Top"
                       Background="Transparent">
                <Button x:Name="TitleBarMinimizeButton" Content="&#xE921;" 
                        Width="30" Height="30" 
                        Click="WindowMinimize_Click" 
                        ToolTip="最小化" FontSize="16" FontFamily="Segoe MDL2 Assets"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E0E0E0"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#C0C0C0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="TitleBarMaxRestoreButton" Content="&#xE922;" 
                        Width="30" Height="30" 
                        Click="WindowMaximize_Click" 
                        ToolTip="最大化" FontSize="16" FontFamily="Segoe MDL2 Assets" 
                        Margin="4,0,0,0"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E0E0E0"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#C0C0C0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="TitleBarCloseButton" Content="&#xE8BB;" 
                        Width="30" Height="30" 
                        Click="WindowClose_Click" 
                        ToolTip="关闭" FontSize="16" FontFamily="Segoe MDL2 Assets" 
                        Margin="4,0,0,0"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E81123"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#C50E1F"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
