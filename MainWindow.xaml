<Window x:Class="OoiMRR.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OoiMRR"
        xmlns:controls="clr-namespace:OoiMRR.Controls"
        xmlns:tagTrain="clr-namespace:TagTrain.UI"
        Title="OoiMRR - 文件资源管理器" 
        Height="800" 
        Width="1200"
        MinHeight="600"
        MinWidth="960"
        WindowState="Normal"
        WindowStyle="SingleBorderWindow"
        AllowsTransparency="False"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        Background="{DynamicResource AppBackgroundBrush}"
        PreviewKeyDown="MainWindow_PreviewKeyDown"
        Closing="Window_Closing"
        LocationChanged="Window_LocationChanged">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="50" 
                      ResizeBorderThickness="4" 
                      GlassFrameThickness="1" 
                      CornerRadius="0" 
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <local:TimeUnitConverter x:Key="TimeUnitConverter"/>
    </Window.Resources>
    
    <!-- 主容器：包含标题栏和窗口内容 -->
    <Grid Name="MainContainer">
        <!-- 窗口内容容器 -->
    <Grid Name="RootGrid" Background="{DynamicResource AppBackgroundBrush}">
        <Grid.Style>
            <Style TargetType="Grid">
                <Setter Property="Margin" Value="0"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                        <Setter Property="Margin" Value="8"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <!-- 左中右3列布局 -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="ColLeft" Width="220" MinWidth="220"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition x:Name="ColCenter" Width="*" MinWidth="250"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition x:Name="ColRight" Width="360" MinWidth="360"/>
        </Grid.ColumnDefinitions>
        
        <!-- 布局：标题栏行 + 标签页行 + 内容行 -->
        <Grid.RowDefinitions>
            <RowDefinition Height="51"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- 标题栏背景（包含底部边框） -->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="5"
                Background="{DynamicResource TitleBarBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Panel.ZIndex="1000"/>
        
        <!-- 导航按钮：位于列0 (随列0宽度自动调整) -->
        <Grid Name="NavButtonsContainer" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0" Panel.ZIndex="1001">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- 导航按钮区域：固定宽度，左对齐 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="8,0" WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Name="NavPathBtn" Click="NavPathBtn_Click" Margin="2,0" Height="32" Width="60"
                        Style="{StaticResource ActiveNavigationButtonStyle}" Tag="Selected"> <!-- 默认选中路径 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="路径" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Name="NavLibraryBtn" Click="NavLibraryBtn_Click" Margin="2,0" Height="32" Width="60"
                        Style="{StaticResource ActiveNavigationButtonStyle}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="库" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Name="NavTagBtn" Click="NavTagBtn_Click" Margin="2,0" Height="32" Width="60"
                        Style="{StaticResource ActiveNavigationButtonStyle}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8EC;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="标签" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            
            <!-- 分隔符 (隐藏保留) -->
            <Separator Name="TitleBarSeparator" Visibility="Collapsed" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center" Height="24" Width="1"/>
        </Grid>

        <!-- 标签页管理器：从列1(Splitter)开始，跨越剩余列 -->
        <controls:TabManagerControl Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="4"
                                    x:Name="TabManager" 
                                    Margin="0,0,250,0"
                                    VerticalAlignment="Center"
                                    Panel.ZIndex="1001"/>



        <!-- ========== 标签页管理器 ========== -->


        <!-- 垂直分割器（从Row 2开始，跨越2行：Row 2和Row 3） -->
        <!-- 左侧导航与中间文件列表之间的分割器 -->
        <controls:CollapsibleGridSplitter x:Name="SplitterLeft" Grid.Row="2" Grid.Column="1" Grid.RowSpan="2"
                      Style="{StaticResource VerticalCollapsibleGridSplitterStyle}"
                      CollapseMode="Previous"
                      ShowsPreview="True"
                      Panel.ZIndex="2000"
                      DragCompleted="GridSplitter_DragCompleted"/>
        
        <!-- 中间文件列表与右侧预览之间的分割器 -->
        <controls:CollapsibleGridSplitter x:Name="SplitterRight" Grid.Row="2" Grid.Column="3" Grid.RowSpan="2"
                      Style="{StaticResource VerticalCollapsibleGridSplitterStyle}"
                      CollapseMode="Both"
                      ShowsPreview="True"
                      Panel.ZIndex="2000"
                      AutoFillNeighbor="True"
                      DragCompleted="GridSplitter_DragCompleted"/>

        <!-- ========== 列1：导航区（独立控件） ========== -->
        <controls:NavigationPanelControl Grid.Row="2" Grid.Column="0" Grid.RowSpan="2" x:Name="NavigationPanelControl"/>

        <!-- ========== 列2：文件显示区 ========== -->
        <controls:FileBrowserControl x:Name="FileBrowser"
                                     Grid.Column="2" 
                                     Grid.Row="1" 
                                     Grid.RowSpan="3"
                                     HorizontalAlignment="Stretch" 
                                     VerticalAlignment="Stretch"
                                     Margin="0,0,0,0"/>

        <!-- ========== 列3：预览/备注区 ========== -->
        <local:RightPanelControl Grid.Row="0" Grid.Column="4" Grid.RowSpan="4"
                                 x:Name="RightPanel"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch"/>

        <!-- 设置覆盖层:覆盖所有内容列,不包括标题栏 -->
        <Grid Name="SettingsOverlay"
              Grid.Row="1" Grid.RowSpan="3"
              Grid.Column="0" Grid.ColumnSpan="5"
              Background="{DynamicResource AppBackgroundBrush}"
              Panel.ZIndex="5000"
              Visibility="Collapsed">
            <controls:SettingsPanelControl x:Name="SettingsPanel"/>
        </Grid>
            <!-- 右上角窗口控制按钮：移动到 RootGrid 内部以保持 Margin 一致性 -->
        <Grid Name="WindowControlButtonsContainer" 
              Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="5"
              HorizontalAlignment="Right" VerticalAlignment="Stretch"
              Panel.ZIndex="10000"
              PreviewMouseDown="WindowControlButtonsContainer_PreviewMouseDown">
            
            <!-- 按钮区域：垂直拉伸填满标题栏 -->
            <StackPanel x:Name="WindowButtonsStackPanel" 
                       Orientation="Horizontal"
                       HorizontalAlignment="Right" VerticalAlignment="Stretch"
                       Margin="0,0,0,0"
                       Background="Transparent"
                       WindowChrome.IsHitTestVisibleInChrome="True">
                
                <!-- 设置按钮 -->
                <Button x:Name="TitleBarSettingsButton" Content="&#xE713;" 
                        Width="46"
                        Click="Settings_Click" 
                        ToolTip="设置" FontSize="16" FontFamily="Segoe MDL2 Assets"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ControlHoverBackgroundBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ControlPressedBackgroundBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <!-- 关于按钮 -->
                <Button x:Name="TitleBarAboutButton" Content="&#xE946;" 
                        Width="46"
                        Click="About_Click" 
                        ToolTip="关于" FontSize="16" FontFamily="Segoe MDL2 Assets"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ControlHoverBackgroundBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ControlPressedBackgroundBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <!-- 最小化按钮 -->
                <Button x:Name="TitleBarMinimizeButton" Content="&#xE921;" 
                        Width="46"
                        Click="WindowMinimize_Click" 
                        ToolTip="最小化" FontSize="16" FontFamily="Segoe MDL2 Assets"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ControlHoverBackgroundBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ControlPressedBackgroundBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="TitleBarMaxRestoreButton" Content="&#xE922;" 
                        Width="46"
                        Click="WindowMaximize_Click" 
                        ToolTip="最大化" FontSize="16" FontFamily="Segoe MDL2 Assets"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ControlHoverBackgroundBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ControlPressedBackgroundBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="TitleBarCloseButton" Content="&#xE8BB;" 
                        Width="46"
                        Click="WindowClose_Click" 
                        ToolTip="关闭" FontSize="16" FontFamily="Segoe MDL2 Assets"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource CloseButtonHoverBackgroundBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource CloseButtonPressedBackgroundBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 通知容器: 位于底部中央，覆盖在最上层 -->
        <StackPanel x:Name="NotificationContainer"
                    Grid.Row="1" Grid.RowSpan="3" Grid.Column="0" Grid.ColumnSpan="5"
                    VerticalAlignment="Bottom" HorizontalAlignment="Center"
                    Margin="0,0,0,20"
                    Panel.ZIndex="9000"/>

    </Grid>
        

    </Grid>
</Window>
