<Window x:Class="OoiMRR.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OoiMRR"
        xmlns:controls="clr-namespace:OoiMRR.Controls"
        xmlns:tagTrain="clr-namespace:TagTrain.UI"
        Title="OoiMRR - 文件资源管理器" 
        Height="800" 
        Width="1200"
        MinHeight="600"
        MinWidth="800"
        WindowState="Normal"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        Background="#FFFFFF"
        PreviewKeyDown="MainWindow_PreviewKeyDown">
    
    <Window.Resources>
        <local:TimeUnitConverter x:Key="TimeUnitConverter"/>
    </Window.Resources>
    
    <!-- 主容器：包含标题栏和窗口内容 -->
    <Grid Name="MainContainer">
        <!-- 窗口内容容器 -->
    <Grid Name="RootGrid" Background="#FFFFFF" Margin="0,0,0,0">
        <!-- 左中右3列布局 -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="ColLeft" Width="300" MinWidth="220"/>
            <ColumnDefinition Width="6"/>
            <ColumnDefinition x:Name="ColCenter" Width="*" MinWidth="250"/>
            <ColumnDefinition Width="6"/>
            <ColumnDefinition x:Name="ColRight" Width="*" MinWidth="360"/>
        </Grid.ColumnDefinitions>
        
        <!-- 布局：标题栏行 + 内容行 -->
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- 标题栏：包含列1导航按钮和列2操作按钮，支持拖拽 -->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="5"
                Background="#F8F9FA" BorderBrush="#E9ECEF" BorderThickness="0,0,0,1"
                MouseDown="TitleBar_MouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- 列1：导航按钮和操作按钮（左侧） -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                    <!-- 固定导航按钮（4个） -->
                    <Button Name="NavPathBtn" Content="路径" Click="NavPathBtn_Click" Margin="2" MinWidth="60">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=NavPathContent, Path=Visibility}" Value="Visible">
                                        <Setter Property="Background" Value="{DynamicResource HighlightBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource HighlightBorderBrush}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Name="NavLibraryBtn" Content="库" Click="NavLibraryBtn_Click" Margin="2" MinWidth="60">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=NavLibraryContent, Path=Visibility}" Value="Visible">
                                        <Setter Property="Background" Value="{DynamicResource HighlightBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource HighlightBorderBrush}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Name="NavTagBtn" Content="标签" Click="NavTagBtn_Click" Margin="2" MinWidth="60">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=NavTagContent, Path=Visibility}" Value="Visible">
                                        <Setter Property="Background" Value="{DynamicResource HighlightBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource HighlightBorderBrush}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    
                    <!-- 分隔符 -->
                <Separator Name="TitleBarSeparator" Margin="12,0" VerticalAlignment="Center" Height="20" Width="1"/>
                    
                    <!-- 动态操作按钮区域（可拖动排序） -->
                    <StackPanel Name="ActionButtonsContainer" Orientation="Horizontal" VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- 列2：占位（原操作按钮区域已移除） -->
                <Grid Grid.Column="1" Name="ActionButtonsGrid" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="8,0">
                    <!-- 隐藏的按钮定义（用于从代码中读取） -->
                    <StackPanel Name="PathActionButtons" Orientation="Horizontal" Visibility="Collapsed">
                        <Button Content="📁 新建文件夹" Click="NewFolder_Click" Margin="0,0,4,0"/>
                        <Button Content="📄 新建文件" Click="NewFile_Click" Margin="0,0,4,0"/>
                        <Separator Margin="16,0"/>
                        <Button Content="复制" Click="Copy_Click" Margin="0,0,4,0"/>
                        <Button Content="粘贴" Click="Paste_Click" Margin="0,0,4,0"/>
                        <Button Content="删除" Click="Delete_Click" Margin="0,0,4,0"/>
                        <Separator Margin="16,0"/>
                        <Button Content="⭐ 添加收藏" Click="AddFavorite_Click" Margin="0,0,4,0"/>
                        <Button Content="🏷️ 添加标签" Click="AddTagToFile_Click" Margin="0,0,4,0"/>
                        <Button Content="🔄 刷新" Click="Refresh_Click"/>
                    </StackPanel>
                    
                    <StackPanel Name="LibraryActionButtons" Orientation="Horizontal" Visibility="Collapsed">
                        <Button Content="📁 新建文件夹" Click="NewFolder_Click" Margin="0,0,4,0"/>
                        <Button Content="📄 新建文件" Click="NewFile_Click" Margin="0,0,4,0"/>
                        <Separator Margin="16,0"/>
                        <Button Content="📚 新建库" Click="AddLibrary_Click" Margin="0,0,4,0"/>
                        <Button Content="📂 添加到库" Click="AddFileToLibrary_Click" Margin="0,0,4,0"/>
                        <Button Content="⚙️ 管理库" Click="ManageLibraries_Click" Margin="0,0,4,0"/>
                        <Separator Margin="16,0"/>
                        <Button Content="复制" Click="Copy_Click" Margin="0,0,4,0"/>
                        <Button Content="粘贴" Click="Paste_Click" Margin="0,0,4,0"/>
                        <Button Content="删除" Click="Delete_Click" Margin="0,0,4,0"/>
                        <Separator Margin="16,0"/>
                        <Button Content="⭐ 添加收藏" Click="AddFavorite_Click" Margin="0,0,4,0"/>
                        <Button Content="🏷️ 添加标签" Click="AddTagToFile_Click" Margin="0,0,4,0"/>
                        <Button Content="🔄 刷新" Click="Refresh_Click"/>
                    </StackPanel>
                    
                    <StackPanel Name="TagActionButtons" Orientation="Horizontal" Visibility="Collapsed">
                        <Button Content="🏷️ 新建标签" Click="NewTag_Click" Margin="0,0,4,0"/>
                        <Button Content="🛠️ 管理标签" Click="ManageTags_Click" Margin="0,0,4,0"/>
                        <Separator Margin="16,0"/>
                        <Button Content="📦 批量添加" Click="BatchAddTags_Click" Margin="0,0,4,0"/>
                        <Button Content="📊 标签统计" Click="TagStatistics_Click"/>
                    </StackPanel>
                </Grid>
                
            </Grid>
        </Border>
        
        <!-- 垂直分割器（从Row 1开始，跨越2行：Row 1和Row 2） -->
        <GridSplitter Grid.Row="1" Grid.Column="1" Grid.RowSpan="2" 
                      Style="{StaticResource VerticalGridSplitterStyle}" DragDelta="GridSplitter_DragDelta"/>
        <GridSplitter Grid.Row="1" Grid.Column="3" Grid.RowSpan="2" 
                      Style="{StaticResource VerticalGridSplitterStyle}"/>
        
        <!-- ========== 列1：导航区 ========== -->
        <!-- 导航按钮已移到标题栏，直接显示内容区域 -->
        <Grid Grid.Row="1" Grid.Column="0" Grid.RowSpan="2" Background="#FFFFFF">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <Grid Name="NavContentGrid" Grid.Row="0">
                <!-- 路径导航内容 -->
                <Grid Name="NavPathContent" Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 子行0：面包屑导航（完整路径，支持多行） -->
                    <Border Grid.Row="0" Background="#FFFFFF" Margin="0,0,0,8">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="4" MaxHeight="120">
                            <WrapPanel Name="BreadcrumbPanel" Orientation="Horizontal"/>
                        </ScrollViewer>
                    </Border>
                    
                    <!-- 驱动器列表 -->
                    <GroupBox Grid.Row="1" Header="驱动器" Margin="0,0,0,8" Style="{StaticResource ModernGroupBoxStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ListBox Name="DrivesListBox" 
                                     Margin="2"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     SelectionMode="Single"
                                     PreviewMouseDown="DrivesListBox_PreviewMouseDown"
                                     ItemContainerStyle="{StaticResource NavListBoxItemStyle}"/>
                        </ScrollViewer>
                    </GroupBox>
                    
                    <!-- 快速访问 -->
                    <GroupBox Grid.Row="2" Header="快速访问" Margin="0,0,0,8" Style="{StaticResource ModernGroupBoxStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ListBox Name="QuickAccessListBox" 
                                     Margin="2"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     SelectionMode="Single"
                                     PreviewMouseDown="QuickAccessListBox_PreviewMouseDown"
                                     ItemContainerStyle="{StaticResource NavListBoxItemStyle}"/>
                        </ScrollViewer>
                    </GroupBox>
                    
                    <!-- 收藏 -->
                    <GroupBox Grid.Row="3" Header="收藏" Style="{StaticResource ModernGroupBoxStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ListBox Name="FavoritesListBox" 
                                     Margin="2"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     SelectionMode="Single"
                                     PreviewMouseDown="FavoritesListBox_PreviewMouseDown"
                                     ItemContainerStyle="{StaticResource NavListBoxItemStyle}"/>
                        </ScrollViewer>
                    </GroupBox>
                </Grid>
                
                <!-- 库导航内容 -->
                <Grid Name="NavLibraryContent" Margin="8" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 库功能按钮已移动到标题栏，此处不再显示 -->
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ListBox Name="LibrariesListBox" 
                                 Margin="2"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 SelectionMode="Single"
                                 SelectionChanged="LibrariesListBox_SelectionChanged"
                                 DisplayMemberPath="Name"
                                 ContextMenuOpening="LibrariesListBox_ContextMenuOpening"
                                 AllowDrop="True"
                                 ItemContainerStyle="{StaticResource NavListBoxItemStyle}">
                            <ListBox.ContextMenu>
                                <ContextMenu Name="LibraryContextMenu">
                                    <MenuItem Header="重命名" Click="LibraryRename_Click" Name="LibraryRenameMenuItem"/>
                                    <MenuItem Header="删除库" Click="LibraryDelete_Click" Name="LibraryDeleteMenuItem"/>
                                    <Separator/>
                                    <MenuItem Header="管理库位置" Click="LibraryManage_Click" Name="LibraryManageMenuItem"/>
                                    <MenuItem Header="在资源管理器中打开" Click="LibraryOpenInExplorer_Click" Name="LibraryOpenInExplorerMenuItem"/>
                                    <Separator/>
                                    <MenuItem Header="刷新库列表" Click="LibraryRefresh_Click"/>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                        </ListBox>
                    </ScrollViewer>
                </Grid>
                
                <!-- 标签导航内容：支持浏览/编辑模式切换 -->
                <Grid Name="NavTagContent" Margin="8" Visibility="Collapsed">
                    <!-- 浏览模式：只显示标签列表（使用TagPanel） -->
                    <tagTrain:TagPanel x:Name="TagBrowsePanel" Mode="Browse" Visibility="Visible"/>
                    
                    <!-- 编辑模式：完整TagTrain训练面板（使用TagPanel） -->
                    <tagTrain:TagPanel x:Name="TagEditPanel" Mode="Edit" Visibility="Collapsed"/>
                </Grid>
            </Grid>
            
            <!-- 底部按钮区：系统按钮 + 标签页面按钮 -->
            <Border Grid.Row="1" Background="#F8F9FA" BorderBrush="#E9ECEF" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 左侧：系统级按钮 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="8,8">
                        <Button Content="⚙️" Click="Settings_Click" Width="32" Height="32" 
                                Style="{StaticResource ModernButtonStyle}" ToolTip="设置" Margin="4,0"/>
                        <Button Content="ℹ️" Click="About_Click" Width="32" Height="32" 
                                Style="{StaticResource ModernButtonStyle}" ToolTip="关于" Margin="4,0"/>
                        <Button Content="🧪" Click="RunVisualTests_Click" Width="32" Height="32" 
                                Style="{StaticResource ModernButtonStyle}" ToolTip="视觉测试" Margin="4,0"/>
                    </StackPanel>
                    
                    <!-- 右侧：标签页面按钮（仅在标签页面显示） -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="8,8" 
                                Visibility="Collapsed" Name="TagBottomButtons">
                        <Button Name="TagClickModeBtn"
                               Content="👁"
                               Click="TagClickModeBtn_Click"
                               Width="32" Height="32"
                               Style="{StaticResource ModernButtonStyle}"
                               ToolTip="切换浏览/编辑模式"
                               Margin="4,0"/>
                        <Button Name="TagCategoryManageBtn"
                               Content="📁"
                               Click="TagCategoryManageBtn_Click"
                               Width="32" Height="32"
                               Style="{StaticResource ModernButtonStyle}"
                               ToolTip="分组管理"
                               Margin="4,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        
        <!-- ========== 列2：文件显示区 ========== -->
        <controls:FileBrowserControl Grid.Row="1" Grid.Column="2" Grid.RowSpan="2"
                                     x:Name="FileBrowser"
                                     FilesSelectionChanged="FileBrowser_FilesSelectionChanged"
                                     FilesMouseDoubleClick="FileBrowser_FilesMouseDoubleClick"
                                     FilesPreviewMouseDoubleClick="FileBrowser_FilesPreviewMouseDoubleClick"
                                     FilesPreviewKeyDown="FileBrowser_FilesPreviewKeyDown"
                                     FilesPreviewMouseLeftButtonDown="FileBrowser_FilesPreviewMouseLeftButtonDown"
                                     FilesMouseLeftButtonUp="FileBrowser_FilesMouseLeftButtonUp"
                                     FilesPreviewMouseDown="FileBrowser_FilesPreviewMouseDown"
                                     GridViewColumnHeaderClick="FileBrowser_GridViewColumnHeaderClick"
                                     FilesSizeChanged="FileBrowser_FilesSizeChanged"
                                     FilesPreviewMouseDoubleClickForBlank="FileBrowser_FilesPreviewMouseDoubleClickForBlank"
                                     PathChanged="FileBrowser_PathChanged"
                                     BreadcrumbClicked="FileBrowser_BreadcrumbClicked"/>

        <!-- ========== 列3：预览/备注区 ========== -->
        <local:RightPanelControl Grid.Row="0" Grid.Column="4" Grid.RowSpan="4"
                                 x:Name="RightPanel"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch"/>
        </Grid>
        
        <!-- 右上角窗口控制按钮：独立的Grid确保可交互，不拦截其他事件 -->
        <Grid Name="WindowControlButtonsContainer" 
              HorizontalAlignment="Right" VerticalAlignment="Top"
              Background="Transparent"
              Width="102" Height="36"
              Panel.ZIndex="10000"
              Margin="0,0,0,0">
            <!-- 按钮区域：固定在右上角 -->
            <StackPanel Orientation="Horizontal"
                       HorizontalAlignment="Right" VerticalAlignment="Top"
                       Background="Transparent">
                <Button x:Name="TitleBarMinimizeButton" Content="&#xE921;" 
                        Width="34" Height="30" 
                        Click="WindowMinimize_Click" 
                        ToolTip="最小化" FontSize="10" FontFamily="Segoe MDL2 Assets"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E5E5E5"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#CCCCCC"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="TitleBarMaxRestoreButton" Content="&#xE922;" 
                        Width="34" Height="30" 
                        Click="WindowMaximize_Click" 
                        ToolTip="最大化" FontSize="10" FontFamily="Segoe MDL2 Assets"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E5E5E5"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#CCCCCC"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="TitleBarCloseButton" Content="&#xE8BB;" 
                        Width="34" Height="30" 
                        Click="WindowClose_Click" 
                        ToolTip="关闭" FontSize="10" FontFamily="Segoe MDL2 Assets"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E81123"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#C50E1F"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
