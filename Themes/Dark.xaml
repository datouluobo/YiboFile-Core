<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Base Colors -->
    <Color x:Key="SystemBaseLowColor">#33FFFFFF</Color>
    <Color x:Key="SystemBaseMediumLowColor">#66FFFFFF</Color>
    <Color x:Key="SystemBaseMediumHighColor">#99FFFFFF</Color>
    <Color x:Key="SystemBaseHighColor">#CCFFFFFF</Color>

    <!-- Chrome Colors -->
    <Color x:Key="SystemChromeLowColor">#FF171717</Color>
    <Color x:Key="SystemChromeMediumLowColor">#FF2C2C2C</Color>
    <Color x:Key="SystemChromeMediumColor">#FF1F1F1F</Color>
    <Color x:Key="SystemChromeMediumHighColor">#FF313131</Color>
    <Color x:Key="SystemChromeHighColor">#FF5A5A5A</Color>

    <!-- Semantic Brushes (Dark Mode) -->

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#202020"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#333333"/>
    <SolidColorBrush x:Key="DialogBackgroundBrush" Color="#2D2D2D"/>

    <!-- Foregrounds -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#ADB5BD"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="#6C757D"/>
    <SolidColorBrush x:Key="TextInverseBrush" Color="#000000"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrush" Color="#404040"/>
    <SolidColorBrush x:Key="BorderStrongBrush" Color="#5A5A5A"/>

    <!-- Accents (Slightly lighter for visibility) -->
    <SolidColorBrush x:Key="AccentBrush" Color="#4DA3FF"/>
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#80BFFF"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#0069D9"/>

    <!-- Control Specific -->
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#4A4A4A"/>
    <SolidColorBrush x:Key="ButtonHoverBackgroundBrush" Color="#4A4A4A"/>

    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#404040"/>

    <!-- Preview Panel Specific -->
    <SolidColorBrush x:Key="PreviewTitleBackgroundBrush" Color="#1F1F1F"/>
    <SolidColorBrush x:Key="PreviewTitleForegroundBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="PreviewPanelBackgroundBrush" Color="#252526"/>
    <SolidColorBrush x:Key="PreviewTextPrimaryBrush" Color="#E0E0E0"/>

    <!-- Status Colors -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#4CAF50"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFC107"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#E57373"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#64B5F6"/>

</ResourceDictionary>
