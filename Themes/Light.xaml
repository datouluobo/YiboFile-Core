<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Base Colors -->
    <Color x:Key="SystemBaseLowColor">#33000000</Color>
    <Color x:Key="SystemBaseMediumLowColor">#66000000</Color>
    <Color x:Key="SystemBaseMediumHighColor">#99000000</Color>
    <Color x:Key="SystemBaseHighColor">#CC000000</Color>

    <!-- Chrome Colors -->
    <Color x:Key="SystemChromeLowColor">#FFE6E6E6</Color>
    <Color x:Key="SystemChromeMediumLowColor">#FFF2F2F2</Color>
    <Color x:Key="SystemChromeMediumColor">#FFE6E6E6</Color>
    <Color x:Key="SystemChromeMediumHighColor">#FFCCCCCC</Color>
    <Color x:Key="SystemChromeHighColor">#FFCCCCCC</Color>

    <!-- Semantic Brushes (Light Mode) -->
    
    <!-- Backgrounds -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#F8F9FA"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="DialogBackgroundBrush" Color="#FFFFFF"/>
    
    <!-- Foregrounds -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#212529"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6C757D"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="#ADB5BD"/>
    <SolidColorBrush x:Key="TextInverseBrush" Color="#FFFFFF"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrush" Color="#DEE2E6"/>
    <SolidColorBrush x:Key="BorderStrongBrush" Color="#CED4DA"/>
    
    <!-- Accents -->
    <Color x:Key="AccentColor">#007BFF</Color>
    <Color x:Key="AccentHoverColor">#0056B3</Color>
    <Color x:Key="AccentPressedColor">#004085</Color>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}"/>
    
    <!-- Control Specific -->
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#E3F2FD"/>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#BBDEFB"/>
    <SolidColorBrush x:Key="ButtonHoverBackgroundBrush" Color="#BBDEFB"/>
    
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#DEE2E6"/>
    
    <!-- Preview Panel Specific (Mapped for backward compatibility but using new keys) -->
    <SolidColorBrush x:Key="PreviewTitleBackgroundBrush" Color="#F8F9FA"/>
    <SolidColorBrush x:Key="PreviewTitleForegroundBrush" Color="#212529"/>
    <SolidColorBrush x:Key="PreviewPanelBackgroundBrush" Color="#F8F9FA"/>
    <SolidColorBrush x:Key="PreviewTextPrimaryBrush" Color="#212529"/>

    <!-- Status Colors -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#28A745"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFC107"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#DC3545"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#17A2B8"/>

</ResourceDictionary>
