<UserControl x:Class="OoiMRR.Controls.MarkdownEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonedit="clr-namespace:ICSharpCode.AvalonEdit;assembly=ICSharpCode.AvalonEdit">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- 左侧：Markdown 编辑器 -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- 工具栏 -->
            <Border Grid.Row="0" Background="#F0F0F0" Padding="5">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="SaveButton" Content="保存" Width="60" Margin="5,0"/>
                    <Button x:Name="RefreshButton" Content="刷新预览" Width="80" Margin="5,0"/>
                </StackPanel>
            </Border>
            
            <!-- 编辑器 -->
            <avalonedit:TextEditor x:Name="MarkdownEditor" Grid.Row="1"
                                   FontFamily="Consolas"
                                   FontSize="14"
                                   ShowLineNumbers="True"
                                   WordWrap="True"/>
        </Grid>
        
        <!-- 分隔线 -->
        <GridSplitter Grid.Column="1" 
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#CCCCCC"
                      ShowsPreview="False"/>
        
        <!-- 右侧：预览 -->
        <Border Grid.Column="2" BorderBrush="#CCCCCC" BorderThickness="1,0,0,0">
            <WebBrowser x:Name="PreviewBrowser"/>
        </Border>
    </Grid>
</UserControl>
