<UserControl x:Class="OoiMRR.Controls.ClipboardHistoryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="350" d:DesignWidth="320">
    <Border Background="{DynamicResource PanelBackgroundBrush}" 
            BorderBrush="{DynamicResource BorderDefaultBrush}" 
            BorderThickness="1" CornerRadius="6"
            Width="320" MaxHeight="400">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="4" Opacity="0.2"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="{DynamicResource PanelBackgroundBrush}" 
                    BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1"
                    CornerRadius="6,6,0,0" Padding="12,8">
                <Grid>
                    <TextBlock Text="📋 剪切板历史" FontWeight="SemiBold" FontSize="14"
                               Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                    <Button x:Name="ClearBtn" Content="清空" HorizontalAlignment="Right"
                            Background="Transparent" BorderThickness="0" Padding="8,4"
                            Foreground="{DynamicResource ForegroundSecondaryBrush}"
                            Click="ClearBtn_Click" Cursor="Hand" FontSize="12"/>
                </Grid>
            </Border>
            
            <!-- Tab 切换 -->
            <TabControl Grid.Row="1" x:Name="HistoryTabs" Background="Transparent" BorderThickness="0"
                        Padding="0" Margin="8,4,8,0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="TabBorder" Background="Transparent" 
                                            Padding="12,6" Margin="0,0,4,0" CornerRadius="4">
                                        <ContentPresenter ContentSource="Header" 
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="TabBorder" Property="Background" 
                                                    Value="{DynamicResource AccentSubtleBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="TabBorder" Property="Background" 
                                                    Value="{DynamicResource ControlHoverBackgroundBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>
                
                <!-- 文件 Tab -->
                <TabItem Header="📁 文件">
                    <ListBox x:Name="FileHistoryList" 
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ItemsSource="{Binding FileHistory}"
                             MouseDoubleClick="HistoryList_MouseDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" Margin="0,2" CornerRadius="4" 
                                        Background="Transparent" Cursor="Hand">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- 图标 -->
                                        <TextBlock Grid.Column="0" Text="📄" FontSize="18" 
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <!-- 预览 -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Preview}" TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource ForegroundBrush}"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding TimeAgo}" FontSize="11"
                                                           Foreground="{DynamicResource ForegroundSecondaryBrush}"/>
                                                <TextBlock Text=" · " FontSize="11" 
                                                           Foreground="{DynamicResource ForegroundSecondaryBrush}"
                                                           Visibility="{Binding IsCut, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                <TextBlock Text="剪切" FontSize="11" 
                                                           Foreground="{DynamicResource WarningBrush}"
                                                           Visibility="{Binding IsCut, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <!-- 删除按钮 -->
                                        <Button Grid.Column="2" Content="✕" FontSize="10"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource ForegroundSecondaryBrush}"
                                                Click="DeleteItem_Click" Tag="{Binding}"
                                                Cursor="Hand" Padding="4" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" 
                                                    CornerRadius="4">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" 
                                                            Value="{DynamicResource ControlHoverBackgroundBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" 
                                                            Value="{DynamicResource AccentSubtleBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </TabItem>
                
                <!-- 文本 Tab -->
                <TabItem Header="📝 文本">
                    <ListBox x:Name="TextHistoryList" 
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ItemsSource="{Binding TextHistory}"
                             MouseDoubleClick="HistoryList_MouseDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" Margin="0,2" CornerRadius="4" 
                                        Background="Transparent" Cursor="Hand">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- 图标 -->
                                        <TextBlock Grid.Column="0" Text="📋" FontSize="18" 
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <!-- 预览 -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Preview}" TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap" MaxWidth="200"
                                                       Foreground="{DynamicResource ForegroundBrush}"/>
                                            <TextBlock Text="{Binding TimeAgo}" FontSize="11"
                                                       Foreground="{DynamicResource ForegroundSecondaryBrush}"/>
                                        </StackPanel>
                                        <!-- 删除按钮 -->
                                        <Button Grid.Column="2" Content="✕" FontSize="10"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource ForegroundSecondaryBrush}"
                                                Click="DeleteItem_Click" Tag="{Binding}"
                                                Cursor="Hand" Padding="4" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" 
                                                    CornerRadius="4">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" 
                                                            Value="{DynamicResource ControlHoverBackgroundBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" 
                                                            Value="{DynamicResource AccentSubtleBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </TabItem>
            </TabControl>
            
            <!-- 空状态提示 -->
            <TextBlock x:Name="EmptyHint" Grid.Row="1" 
                       Text="暂无历史记录" 
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{DynamicResource ForegroundSecondaryBrush}"
                       Visibility="Collapsed"/>
            
            <!-- 底部提示 -->
            <Border Grid.Row="2" Padding="8,6" 
                    BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,1,0,0">
                <TextBlock Text="双击项目可粘贴到当前位置" FontSize="11" 
                           Foreground="{DynamicResource ForegroundSecondaryBrush}"
                           HorizontalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
