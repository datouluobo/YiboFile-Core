<UserControl x:Class="OoiMRR.Controls.TabManagerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="800">
    <Border x:Name="TabsBorder" Background="#F8F9FA" BorderBrush="#E9ECEF" BorderThickness="0,0,0,1" Visibility="Collapsed">
        <Grid Margin="8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- 标签页区域 -->
            <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel x:Name="TabsPanel" Orientation="Horizontal"/>
            </ScrollViewer>
            
            <!-- 视图切换工具栏 -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0,0,0">
                <!-- 详细信息视图按钮 -->
                <Button x:Name="BtnViewDetails"
                        Style="{StaticResource ViewToggleButtonStyle}"
                        Click="BtnViewDetails_Click"
                        ToolTip="详细信息视图">
                    <Grid Width="12" Height="12">
                        <Rectangle Width="12" Height="1" Fill="#495057" VerticalAlignment="Top" Margin="0,1"/>
                        <Rectangle Width="12" Height="1" Fill="#495057" VerticalAlignment="Center" Margin="0,0"/>
                        <Rectangle Width="12" Height="1" Fill="#495057" VerticalAlignment="Bottom" Margin="0,1"/>
                    </Grid>
                </Button>
                <!-- 缩略图视图按钮 -->
                <Button x:Name="BtnViewTiles"
                        Style="{StaticResource ViewToggleButtonStyle}"
                        Click="BtnViewTiles_Click"
                        ToolTip="缩略图视图">
                    <Grid Width="12" Height="12">
                        <Rectangle Width="5" Height="5" Fill="#495057" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <Rectangle Width="5" Height="5" Fill="#495057" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                        <Rectangle Width="5" Height="5" Fill="#495057" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                        <Rectangle Width="5" Height="5" Fill="#495057" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                    </Grid>
                </Button>
                <!-- 缩略图大小调节，仅在缩略图视图下有意义 -->
                <Slider x:Name="ThumbnailSizeSlider"
                        Minimum="80"
                        Maximum="256"
                        Value="128"
                        Width="80"
                        Margin="4,0,0,0"
                        VerticalAlignment="Center"
                        ToolTip="缩略图大小"
                        ValueChanged="ThumbnailSizeSlider_ValueChanged"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

