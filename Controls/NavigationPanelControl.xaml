<UserControl x:Class="OoiMRR.Controls.NavigationPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tagTrain="clr-namespace:TagTrain.UI"
             Background="#FFFFFF">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Grid Name="NavContentGrid" Grid.Row="0">
            <!-- 路径导航内容 -->
            <Grid Name="NavPathContent" Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- 子行0：面包屑导航（完整路径，支持多行） -->
                <Border Grid.Row="0" Background="#FFFFFF" Margin="0,0,0,8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="4" MaxHeight="120">
                        <WrapPanel Name="BreadcrumbPanel" Orientation="Horizontal"/>
                    </ScrollViewer>
                </Border>
                
                <!-- 驱动器列表 -->
                <GroupBox Grid.Row="1" Header="驱动器" Margin="0,0,0,8" Style="{StaticResource ModernGroupBoxStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ListBox Name="DrivesListBox" 
                                 Margin="2"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 SelectionMode="Single"
                                 ItemContainerStyle="{StaticResource NavListBoxItemStyle}"/>
                    </ScrollViewer>
                </GroupBox>
                
                <!-- 快速访问 -->
                <GroupBox Grid.Row="2" Header="快速访问" Margin="0,0,0,8" Style="{StaticResource ModernGroupBoxStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ListBox Name="QuickAccessListBox" 
                                 Margin="2"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 SelectionMode="Single"
                                 ItemContainerStyle="{StaticResource NavListBoxItemStyle}"/>
                    </ScrollViewer>
                </GroupBox>
                
                <!-- 收藏 -->
                <GroupBox Grid.Row="3" Header="收藏" Style="{StaticResource ModernGroupBoxStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ListBox Name="FavoritesListBox" 
                                 Margin="2"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 SelectionMode="Single"
                                 ItemContainerStyle="{StaticResource NavListBoxItemStyle}"/>
                    </ScrollViewer>
                </GroupBox>
            </Grid>
            
            <!-- 库导航内容 -->
            <Grid Name="NavLibraryContent" Margin="8" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ListBox Name="LibrariesListBox" 
                             Margin="2"
                             BorderThickness="0"
                             Background="Transparent"
                             SelectionMode="Single"
                             DisplayMemberPath="Name"
                             AllowDrop="True"
                             ItemContainerStyle="{StaticResource NavListBoxItemStyle}">
                        <ListBox.ContextMenu>
                            <ContextMenu Name="LibraryContextMenu">
                                <MenuItem Header="📂 添加到库" Name="AddFileToLibraryMenuItem"/>
                                <Separator/>
                                <MenuItem Header="重命名" Name="LibraryRenameMenuItem"/>
                                <MenuItem Header="删除库" Name="LibraryDeleteMenuItem"/>
                                <Separator/>
                                <MenuItem Header="管理库" Name="LibraryManageMenuItem"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                    </ListBox>
                </ScrollViewer>
            </Grid>
            
            <!-- 标签导航内容：支持浏览/编辑模式切换 -->
            <Grid Name="NavTagContent" Margin="8" Visibility="Collapsed">
                <!-- 浏览模式：只显示标签列表（使用TagPanel） -->
                <tagTrain:TagPanel x:Name="TagBrowsePanel" Mode="Browse" Visibility="Visible"/>
                
                <!-- 编辑模式：完整TagTrain训练面板（使用TagPanel） -->
                <tagTrain:TagPanel x:Name="TagEditPanel" Mode="Edit" Visibility="Collapsed"/>
            </Grid>
        </Grid>
        
        <!-- 底部按钮区：系统按钮 + 标签页面按钮 + 库管理按钮 -->
        <Border Grid.Row="1" Background="#F8F9FA" BorderBrush="#E9ECEF" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- 左侧：添加收藏/标签按钮 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="8,8">
                    <Button Content="❤️" Name="AddFavoriteButton" Width="32" Height="32"
                            Style="{StaticResource ModernButtonStyle}" ToolTip="添加收藏" Margin="0,0,4,0"/>
                    <Button Content="📌" Name="AddTagToFileButton" Width="32" Height="32"
                            Style="{StaticResource ModernButtonStyle}" ToolTip="添加标签" Margin="0,0,4,0"/>
                </StackPanel>
                
                <!-- 右侧：库管理按钮（仅在库模式显示）+ 标签页面按钮（仅在标签页面显示） -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="8,8">
                    <!-- 库管理按钮 -->
                    <StackPanel Orientation="Horizontal" Name="LibraryBottomButtons" Visibility="Collapsed">
                        <Button Name="LibraryManageBtn"
                               Content="⚙️ 管理库"
                               Height="32"
                               Style="{StaticResource ModernButtonStyle}"
                               ToolTip="管理库（包含新建库功能）"
                               Margin="4,0"/>
                        <Button Name="LibraryRefreshBtn"
                               Content="🔄 刷新"
                               Height="32"
                               Style="{StaticResource ModernButtonStyle}"
                               ToolTip="刷新库列表"
                               Margin="4,0"/>
                    </StackPanel>
                    
                    <!-- 标签页面按钮 -->
                    <StackPanel Orientation="Horizontal" Visibility="Collapsed" Name="TagBottomButtons">
                        <Button Name="TagClickModeBtn"
                               Content="👁"
                               Width="32" Height="32"
                               Style="{StaticResource ModernButtonStyle}"
                               ToolTip="切换浏览/编辑模式"
                               Margin="4,0"/>
                        <Button Name="TagCategoryManageBtn"
                               Content="📁"
                               Width="32" Height="32"
                               Style="{StaticResource ModernButtonStyle}"
                               ToolTip="分组管理"
                               Margin="4,0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>



