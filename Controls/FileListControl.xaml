<UserControl x:Class="OoiMRR.Controls.FileListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:OoiMRR.ViewModels"
             xmlns:colmgr="clr-namespace:OoiMRR.Services.UI.ColumnManagement"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        
        <!-- 缩略图视图模板 -->
        <DataTemplate x:Key="ThumbnailTemplate">
            <Border Width="120" Height="140" Margin="5" Background="Transparent">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="100"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Margin="4" Background="{DynamicResource BackgroundSecondaryBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4">
                        <!-- 缩略图 Image，初始为空，Source由ThumbnailViewManager异步加载 -->
                        <Image Source="{Binding Icon}" Stretch="Uniform" Margin="4"/>
                    </Border>
                    
                    <TextBlock Grid.Row="1" Text="{Binding Name}" 
                               TextAlignment="Center" 
                               TextWrapping="Wrap" 
                               MaxHeight="36" 
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding Name}"/>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- 自定义列头样式：增大分隔线点击热区 -->
        <Style x:Key="FileListColumnHeaderStyle" TargetType="{x:Type GridViewColumnHeader}">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <!-- 绑定 Tag 属性到内容的 Tag (假定内容是 FrameworkElement) -->
            <Setter Property="Tag" Value="{Binding Content.Tag, RelativeSource={RelativeSource Self}}"/>
            <EventSetter Event="Click" Handler="ColumnHeader_Click"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type GridViewColumnHeader}">
                        <Grid>
                            <Border BorderThickness="{TemplateBinding BorderThickness}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    Background="{TemplateBinding Background}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <ContentPresenter Grid.Column="0"
                                                      Margin="{TemplateBinding Padding}" 
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                      RecognizesAccessKey="True"
                                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                    
                                    <!-- 排序箭头 - 升序 -->
                                    <Path x:Name="SortArrowAsc"
                                          Grid.Column="1"
                                          Visibility="Collapsed"
                                          Data="M 0,5 L 8,5 L 4,0 Z"
                                          Fill="{DynamicResource AccentDefaultBrush}"
                                          Margin="4,0,8,0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Right"/>
                                    
                                    <!-- 排序箭头 - 降序 -->
                                    <Path x:Name="SortArrowDesc"
                                          Grid.Column="1"
                                          Visibility="Collapsed"
                                          Data="M 0,0 L 8,0 L 4,5 Z"
                                          Fill="{DynamicResource AccentDefaultBrush}"
                                          Margin="4,0,8,0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                            <!-- Gripper: 宽度8px的透明热区，右对齐，在列头内部 -->
                            <Thumb x:Name="PART_HeaderGripper" 
                                   HorizontalAlignment="Right" 
                                   Margin="0" 
                                   Width="8"
                                   Cursor="SizeWE">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Border x:Name="GripperBorder" Background="Transparent"/>
                                        <ControlTemplate.Triggers>
                                            <!-- 悬停时显示蓝色竖条 -->
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="GripperBorder" Property="Background" Value="#2196F3"/>
                                                <Setter TargetName="GripperBorder" Property="Opacity" Value="0.5"/>
                                            </Trigger>
                                            <!-- 拖动时加深颜色 -->
                                            <Trigger Property="IsDragging" Value="True">
                                                <Setter TargetName="GripperBorder" Property="Background" Value="#2196F3"/>
                                                <Setter TargetName="GripperBorder" Property="Opacity" Value="0.8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- 优化悬停效果 - 更明显的蓝色背景 -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E3F2FD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#BBDEFB"/>
                            </Trigger>
                            
                            <!-- 升序箭头（向上） -->
                            <DataTrigger Binding="{Binding Path=(colmgr:ColumnHeaderSortHelper.SortDirection), RelativeSource={RelativeSource Self}}" Value="Ascending">
                                <Setter TargetName="SortArrowAsc" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            
                            <!-- 降序箭头（向下） -->
                            <DataTrigger Binding="{Binding Path=(colmgr:ColumnHeaderSortHelper.SortDirection), RelativeSource={RelativeSource Self}}" Value="Descending">
                                <Setter TargetName="SortArrowDesc" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 不可调整大小的列头样式 -->
        <Style x:Key="NonResizableFileColumnHeaderStyle" TargetType="{x:Type GridViewColumnHeader}" BasedOn="{StaticResource FileListColumnHeaderStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type GridViewColumnHeader}">
                        <Grid>
                            <Border BorderThickness="{TemplateBinding BorderThickness}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    Background="{TemplateBinding Background}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <ContentPresenter Grid.Column="0"
                                                      Margin="{TemplateBinding Padding}" 
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                      RecognizesAccessKey="True"
                                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                    
                                    <!-- 排序箭头 - 升序 -->
                                    <Path x:Name="SortArrowAsc"
                                          Grid.Column="1"
                                          Visibility="Collapsed"
                                          Data="M 0,5 L 8,5 L 4,0 Z"
                                          Fill="{DynamicResource AccentDefaultBrush}"
                                          Margin="4,0,8,0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Right"/>
                                    
                                    <!-- 排序箭头 - 降序 -->
                                    <Path x:Name="SortArrowDesc"
                                          Grid.Column="1"
                                          Visibility="Collapsed"
                                          Data="M 0,0 L 8,0 L 4,5 Z"
                                          Fill="{DynamicResource AccentDefaultBrush}"
                                          Margin="4,0,8,0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                            <!-- 无 Gripper -->
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- 优化悬停效果 - 与可调整大小的列头保持一致 -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E3F2FD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#BBDEFB"/>
                            </Trigger>
                            
                            <!-- 升序箭头（向上） -->
                            <DataTrigger Binding="{Binding Path=(colmgr:ColumnHeaderSortHelper.SortDirection), RelativeSource={RelativeSource Self}}" Value="Ascending">
                                <Setter TargetName="SortArrowAsc" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            
                            <!-- 降序箭头（向下） -->
                            <DataTrigger Binding="{Binding Path=(colmgr:ColumnHeaderSortHelper.SortDirection), RelativeSource={RelativeSource Self}}" Value="Descending">
                                <Setter TargetName="SortArrowDesc" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <!-- 文件列表 -->
        <Border Background="{DynamicResource AppBackgroundBrush}">
            <Grid>
                <!-- 普通列表视图 -->
                <ListView x:Name="FilesListView" 
                      SelectionMode="Extended"
                      Background="{DynamicResource AppBackgroundBrush}"
                      BorderThickness="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <!-- 文件名日期匹配 - 蓝色背景 -->
                                <DataTrigger Binding="{Binding Notes}" Value="文件名日期匹配">
                                    <Setter Property="Background" Value="#E3F2FD"/>
                                    <Setter Property="BorderBrush" Value="#BBDEFB"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                </DataTrigger>
                                <!-- 文件日期匹配 - 绿色背景 -->
                                <DataTrigger Binding="{Binding Notes}" Value="创建日期匹配">
                                    <Setter Property="Background" Value="#E8F5E9"/>
                                    <Setter Property="BorderBrush" Value="#C8E6C9"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Notes}" Value="修改日期匹配">
                                    <Setter Property="Background" Value="#E8F5E9"/>
                                    <Setter Property="BorderBrush" Value="#C8E6C9"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Notes}" Value="创建/修改日期匹配">
                                    <Setter Property="Background" Value="#E8F5E9"/>
                                    <Setter Property="BorderBrush" Value="#C8E6C9"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                </DataTrigger>
                                <!-- 选中状态 -->
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#64B5F6"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsSelected" Value="True"/>
                                        <Condition Property="IsMouseOver" Value="True"/>
                                    </MultiTrigger.Conditions>
                                    <Setter Property="Background" Value="#42A5F5"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                </MultiTrigger>
                                <!-- 鼠标悬停 -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E3F2FD"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView x:Name="FilesGridView" ColumnHeaderContainerStyle="{StaticResource FileListColumnHeaderStyle}">
                            <GridViewColumn x:Name="ColName" DisplayMemberBinding="{Binding Name}">
                                <GridViewColumn.Header>
                                    <TextBlock Text="名称" Tag="Name"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            
                            <GridViewColumn x:Name="ColType" Width="60" HeaderContainerStyle="{StaticResource NonResizableFileColumnHeaderStyle}" DisplayMemberBinding="{Binding Type}">
                                <GridViewColumn.Header>
                                    <TextBlock Text="类型" Tag="Type"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>

                            <GridViewColumn x:Name="ColSize" Width="90" HeaderContainerStyle="{StaticResource NonResizableFileColumnHeaderStyle}">
                                <GridViewColumn.Header>
                                    <TextBlock Text="大小" Tag="Size"/>
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Size}" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn x:Name="ColModifiedDate" Width="100" HeaderContainerStyle="{StaticResource NonResizableFileColumnHeaderStyle}" DisplayMemberBinding="{Binding ModifiedDate}">
                                <GridViewColumn.Header>
                                    <TextBlock Text="修改日期" Tag="ModifiedDate"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>

                            <GridViewColumn Width="60" HeaderContainerStyle="{StaticResource NonResizableFileColumnHeaderStyle}">
                                <GridViewColumn.Header>
                                    <TextBlock Text="创建" Tag="CreatedTime"/>
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding CreatedTimeBrush}" Margin="-6,0" Padding="8,2" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                                            <TextBlock Text="{Binding CreatedTime}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Black"/>
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            
                            <!-- Tags and Notes columns with configurable widths -->
                            <GridViewColumn x:Name="ColTags" Width="150" HeaderContainerStyle="{StaticResource NonResizableFileColumnHeaderStyle}" DisplayMemberBinding="{Binding Tags}">
                                <GridViewColumn.Header>
                                    <TextBlock Text="标签" Tag="Tags"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn x:Name="ColNotes" Width="200" HeaderContainerStyle="{StaticResource NonResizableFileColumnHeaderStyle}" DisplayMemberBinding="{Binding Notes}">
                                <GridViewColumn.Header>
                                    <TextBlock Text="备注" Tag="Notes"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
                
                <!-- 分组列表视图 -->
                <Grid x:Name="GroupedResultsViewer" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" 
                            Background="{DynamicResource BackgroundTertiaryBrush}" 
                            BorderBrush="{DynamicResource BorderDefaultBrush}" 
                            BorderThickness="0,0,0,1">
                        <ListView x:Name="GroupedHeaderListView" BorderThickness="0" Background="Transparent">
                            <ListView.View>
                                <GridView ColumnHeaderContainerStyle="{StaticResource FileListColumnHeaderStyle}">
                                    <GridViewColumn x:Name="ColHeaderName" Width="250">
                                        <GridViewColumn.Header>
                                            <TextBlock Text="名称" Tag="Name"/>
                                        </GridViewColumn.Header>
                                    </GridViewColumn>
                                    
                                    <GridViewColumn x:Name="ColHeaderType" Width="60" HeaderContainerStyle="{StaticResource NonResizableFileColumnHeaderStyle}">
                                        <GridViewColumn.Header>
                                            <TextBlock Text="类型" Tag="Type"/>
                                        </GridViewColumn.Header>
                                    </GridViewColumn>

                                    <GridViewColumn x:Name="ColHeaderSize" Width="90" HeaderContainerStyle="{StaticResource NonResizableFileColumnHeaderStyle}">
                                        <GridViewColumn.Header>
                                            <TextBlock Text="大小" Tag="Size"/>
                                        </GridViewColumn.Header>
                                    </GridViewColumn>
                                    
                                    <GridViewColumn x:Name="ColHeaderModifiedDate" Width="100" HeaderContainerStyle="{StaticResource NonResizableFileColumnHeaderStyle}">
                                        <GridViewColumn.Header>
                                            <TextBlock Text="修改日期" Tag="ModifiedDate"/>
                                        </GridViewColumn.Header>
                                    </GridViewColumn>
                                    
                                    <GridViewColumn x:Name="ColHeaderCreatedTime" Width="60" HeaderContainerStyle="{StaticResource NonResizableFileColumnHeaderStyle}">
                                        <GridViewColumn.Header>
                                            <TextBlock Text="创建" Tag="CreatedTime"/>
                                        </GridViewColumn.Header>
                                    </GridViewColumn>
                                    
                                    <GridViewColumn x:Name="ColHeaderTags" Width="150">
                                        <GridViewColumn.Header>
                                            <TextBlock Text="标签" Tag="Tags"/>
                                        </GridViewColumn.Header>
                                    </GridViewColumn>
                                    <GridViewColumn x:Name="ColHeaderNotes" Width="200">
                                        <GridViewColumn.Header>
                                            <TextBlock Text="备注" Tag="Notes"/>
                                        </GridViewColumn.Header>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>
                    
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="GroupedResultsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:SearchResultGroupViewModel}">
                                    <Border Background="{Binding GroupBackground}" 
                                            BorderBrush="{Binding GroupBorderBrush}"
                                            BorderThickness="0,0,0,2"
                                            Margin="0,0,0,8">
                                        <StackPanel>
                                            <Border Background="{Binding GroupBackground}" 
                                                    BorderBrush="{Binding GroupBorderBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="12,8"
                                                    Cursor="Hand"
                                                    MouseLeftButtonDown="GroupHeader_MouseLeftButtonDown">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <TextBlock Grid.Column="0" 
                                                               Text="{Binding ExpandIcon}" 
                                                               FontSize="16"
                                                               FontWeight="Bold"
                                                               Foreground="{DynamicResource ForegroundSecondaryBrush}"
                                                               Margin="0,0,12,0"
                                                               VerticalAlignment="Center"/>
                                                    
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                        <TextBlock Text="{Binding GroupName}" 
                                                                   FontWeight="SemiBold"
                                                                   FontSize="14"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding ItemCount, StringFormat=' ({0})'}" 
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource ForegroundSecondaryBrush}"
                                                                   Margin="8,0,0,0"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            
                                            <ListView ItemsSource="{Binding Items}"
                                                      SelectionMode="Extended"
                                                      BorderThickness="0"
                                                      Background="Transparent"
                                                      Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <ListView.ItemContainerStyle>
                                                    <Style TargetType="ListViewItem">
                                                        <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}"/>
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter Property="Background" Value="#64B5F6"/>
                                                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                                            </Trigger>
                                                            <MultiTrigger>
                                                                <MultiTrigger.Conditions>
                                                                    <Condition Property="IsSelected" Value="True"/>
                                                                    <Condition Property="IsMouseOver" Value="True"/>
                                                                </MultiTrigger.Conditions>
                                                                <Setter Property="Background" Value="#42A5F5"/>
                                                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                                            </MultiTrigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#E3F2FD"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ListView.ItemContainerStyle>
                                                <ListView.View>
                                                    <GridView>
                                                        <GridViewColumn Width="{Binding ElementName=ColHeaderName, Path=Width}" DisplayMemberBinding="{Binding Name}"/>
                                                        <GridViewColumn Width="{Binding ElementName=ColHeaderType, Path=Width}" DisplayMemberBinding="{Binding Type}"/>
                                                        <GridViewColumn Width="{Binding ElementName=ColHeaderSize, Path=Width}">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding Size}" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Width="{Binding ElementName=ColHeaderModifiedDate, Path=Width}" DisplayMemberBinding="{Binding ModifiedDate}"/>
                                                        <GridViewColumn Width="{Binding ElementName=ColHeaderCreatedTime, Path=Width}">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="{Binding CreatedTimeBrush}" Margin="-6,0" Padding="8,2" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                                                                        <TextBlock Text="{Binding CreatedTime}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Black"/>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Width="{Binding ElementName=ColHeaderTags, Path=Width}" DisplayMemberBinding="{Binding Tags}"/>
                                                        <GridViewColumn Width="{Binding ElementName=ColHeaderNotes, Path=Width}" DisplayMemberBinding="{Binding Notes}"/>
                                                    </GridView>
                                                </ListView.View>
                                                <ListView.Resources>
                                                    <Style TargetType="GridViewColumnHeader">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </Style>
                                                </ListView.Resources>
                                            </ListView>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
                
                <!-- 加载更多按钮 -->
                <Button x:Name="LoadMoreBtn" Content="加载更多" Width="88" Height="28"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="8"
                        Visibility="Collapsed" Click="LoadMoreBtn_Click"/>
                
                <!-- 空状态提示 -->
                <TextBlock x:Name="EmptyStateText" 
                           Text="暂无文件"
                           FontSize="16"
                           Foreground="{DynamicResource ForegroundSecondaryBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>

