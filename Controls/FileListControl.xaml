<UserControl x:Class="OoiMRR.Controls.FileListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:OoiMRR.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid>
        <!-- 文件列表 -->
        <Border Background="#FFFFFF" BorderBrush="#E9ECEF" BorderThickness="0,1,0,0">
            <Grid>
                <!-- 普通列表视图 -->
                <ListView x:Name="FilesListView" 
                      SelectionMode="Extended"
                      Background="#FFFFFF">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="#FFFFFF"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <!-- 文件名日期匹配 - 蓝色背景 -->
                                <DataTrigger Binding="{Binding Notes}" Value="文件名日期匹配">
                                    <Setter Property="Background" Value="#E3F2FD"/>
                                    <Setter Property="BorderBrush" Value="#BBDEFB"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                </DataTrigger>
                                <!-- 文件日期匹配 - 绿色背景 -->
                                <DataTrigger Binding="{Binding Notes}" Value="创建日期匹配">
                                    <Setter Property="Background" Value="#E8F5E9"/>
                                    <Setter Property="BorderBrush" Value="#C8E6C9"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Notes}" Value="修改日期匹配">
                                    <Setter Property="Background" Value="#E8F5E9"/>
                                    <Setter Property="BorderBrush" Value="#C8E6C9"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Notes}" Value="创建/修改日期匹配">
                                    <Setter Property="Background" Value="#E8F5E9"/>
                                    <Setter Property="BorderBrush" Value="#C8E6C9"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                </DataTrigger>
                                <!-- 选中状态 -->
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#64B5F6"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsSelected" Value="True"/>
                                        <Condition Property="IsMouseOver" Value="True"/>
                                    </MultiTrigger.Conditions>
                                    <Setter Property="Background" Value="#42A5F5"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                </MultiTrigger>
                                <!-- 鼠标悬停 -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E3F2FD"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView x:Name="FilesGridView">
                            <GridViewColumn Width="200" DisplayMemberBinding="{Binding Name}">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="名称" Tag="Name"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn x:Name="ColSize" Width="100" DisplayMemberBinding="{Binding Size}">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="大小" Tag="Size"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn x:Name="ColType" Width="100" DisplayMemberBinding="{Binding Type}">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="类型" Tag="Type"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn Width="150" DisplayMemberBinding="{Binding ModifiedDate}">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="修改日期" Tag="ModifiedDate"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn Width="50">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="创建" Tag="CreatedTime"/>
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <TextBlock.Text>
                                                <Binding Path="CreatedTime"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="150" DisplayMemberBinding="{Binding Tags}">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="标签" Tag="Tags"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn Width="200" DisplayMemberBinding="{Binding Notes}">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="备注" Tag="Notes"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
                
                <!-- 分组列表视图 -->
                <Grid x:Name="GroupedResultsViewer" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 统一的列头（只显示一次） -->
                    <Border Grid.Row="0" 
                            Background="#F5F5F5" 
                            BorderBrush="#E0E0E0" 
                            BorderThickness="0,0,0,1">
                        <ListView x:Name="GroupedHeaderListView" BorderThickness="0" Background="Transparent">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn x:Name="ColHeaderName" Width="200">
                                        <GridViewColumn.Header>
                                            <GridViewColumnHeader Content="名称" Tag="Name"/>
                                        </GridViewColumn.Header>
                                    </GridViewColumn>
                                    <GridViewColumn x:Name="ColHeaderSize" Width="100">
                                        <GridViewColumn.Header>
                                            <GridViewColumnHeader Content="大小" Tag="Size"/>
                                        </GridViewColumn.Header>
                                    </GridViewColumn>
                                    <GridViewColumn x:Name="ColHeaderType" Width="100">
                                        <GridViewColumn.Header>
                                            <GridViewColumnHeader Content="类型" Tag="Type"/>
                                        </GridViewColumn.Header>
                                    </GridViewColumn>
                                    <GridViewColumn x:Name="ColHeaderModifiedDate" Width="150">
                                        <GridViewColumn.Header>
                                            <GridViewColumnHeader Content="修改日期" Tag="ModifiedDate"/>
                                        </GridViewColumn.Header>
                                    </GridViewColumn>
                                    <GridViewColumn x:Name="ColHeaderCreatedTime" Width="50">
                                        <GridViewColumn.Header>
                                            <GridViewColumnHeader Content="创建" Tag="CreatedTime"/>
                                        </GridViewColumn.Header>
                                    </GridViewColumn>
                                    <GridViewColumn x:Name="ColHeaderTags" Width="150">
                                        <GridViewColumn.Header>
                                            <GridViewColumnHeader Content="标签" Tag="Tags"/>
                                        </GridViewColumn.Header>
                                    </GridViewColumn>
                                    <GridViewColumn x:Name="ColHeaderNotes" Width="200">
                                        <GridViewColumn.Header>
                                            <GridViewColumnHeader Content="备注" Tag="Notes"/>
                                        </GridViewColumn.Header>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>
                    
                    <!-- 分组内容区域 -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="GroupedResultsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:SearchResultGroupViewModel}">
                                    <Border Background="{Binding GroupBackground}" 
                                            BorderBrush="{Binding GroupBorderBrush}"
                                            BorderThickness="0,0,0,2"
                                            Margin="0,0,0,8">
                                        <StackPanel>
                                            <!-- 分组标题（可折叠） -->
                                            <Border Background="{Binding GroupBackground}" 
                                                    BorderBrush="{Binding GroupBorderBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="12,8"
                                                    Cursor="Hand"
                                                    MouseLeftButtonDown="GroupHeader_MouseLeftButtonDown">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <!-- 折叠/展开图标 -->
                                                    <TextBlock Grid.Column="0" 
                                                               Text="{Binding ExpandIcon}" 
                                                               FontSize="16"
                                                               FontWeight="Bold"
                                                               Foreground="#666666"
                                                               Margin="0,0,12,0"
                                                               VerticalAlignment="Center"/>
                                                    
                                                    <!-- 分组名称和计数 -->
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                        <TextBlock Text="{Binding GroupName}" 
                                                                   FontWeight="SemiBold"
                                                                   FontSize="14"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding ItemCount, StringFormat=' ({0})'}" 
                                                                   FontSize="12"
                                                                   Foreground="#666666"
                                                                   Margin="8,0,0,0"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            
                                            <!-- 分组内容（可折叠，使用ListView+GridView，隐藏列头） -->
                                            <ListView ItemsSource="{Binding Items}"
                                                      SelectionMode="Extended"
                                                      BorderThickness="0"
                                                      Background="Transparent"
                                                      Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <ListView.ItemContainerStyle>
                                                    <Style TargetType="ListViewItem">
                                                        <Setter Property="Background" Value="#FFFFFF"/>
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter Property="Background" Value="#64B5F6"/>
                                                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                                            </Trigger>
                                                            <MultiTrigger>
                                                                <MultiTrigger.Conditions>
                                                                    <Condition Property="IsSelected" Value="True"/>
                                                                    <Condition Property="IsMouseOver" Value="True"/>
                                                                </MultiTrigger.Conditions>
                                                                <Setter Property="Background" Value="#42A5F5"/>
                                                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                                            </MultiTrigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#E3F2FD"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ListView.ItemContainerStyle>
                                                <ListView.View>
                                                    <GridView>
                                                        <GridViewColumn Width="{Binding ElementName=ColHeaderName, Path=Width}" DisplayMemberBinding="{Binding Name}"/>
                                                        <GridViewColumn Width="{Binding ElementName=ColHeaderSize, Path=Width}" DisplayMemberBinding="{Binding Size}"/>
                                                        <GridViewColumn Width="{Binding ElementName=ColHeaderType, Path=Width}" DisplayMemberBinding="{Binding Type}"/>
                                                        <GridViewColumn Width="{Binding ElementName=ColHeaderModifiedDate, Path=Width}" DisplayMemberBinding="{Binding ModifiedDate}"/>
                                                        <GridViewColumn Width="{Binding ElementName=ColHeaderCreatedTime, Path=Width}">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding CreatedTime}">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Foreground" Value="Black"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=IsSelected}" Value="True">
                                                                                        <Setter Property="Foreground" Value="White"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Width="{Binding ElementName=ColHeaderTags, Path=Width}" DisplayMemberBinding="{Binding Tags}"/>
                                                        <GridViewColumn Width="{Binding ElementName=ColHeaderNotes, Path=Width}" DisplayMemberBinding="{Binding Notes}"/>
                                                    </GridView>
                                                </ListView.View>
                                                <ListView.Resources>
                                                    <Style TargetType="GridViewColumnHeader">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </Style>
                                                </ListView.Resources>
                                            </ListView>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
                
                <!-- 加载更多按钮 -->
                <Button x:Name="LoadMoreBtn" Content="加载更多" Width="88" Height="28"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="8"
                        Visibility="Collapsed" Click="LoadMoreBtn_Click"/>
                
                <!-- 空状态提示 -->
                <TextBlock x:Name="EmptyStateText" 
                           Text="暂无文件"
                           FontSize="16"
                           Foreground="#999999"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>

