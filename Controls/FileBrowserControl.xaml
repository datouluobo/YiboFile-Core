<UserControl x:Class="OoiMRR.Controls.FileBrowserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:OoiMRR.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Row 0: 地址栏 -->
            <RowDefinition Height="Auto"/>  <!-- Row 1: 工具栏行 -->
            <RowDefinition Height="*"/>     <!-- Row 2: 文件列表 -->
            <RowDefinition Height="12"/>     <!-- Row 3: Splitter -->
            <RowDefinition Height="180" MinHeight="120"/> <!-- Row 4: Info Panel -->
        </Grid.RowDefinitions>
        
        <Grid.Resources>
            <!-- 统一使用 AppStyles 中的 ModernToolbarButtonStyle -->
            <Style x:Key="ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernToolbarButtonStyle}"/>
            
            <Style x:Key="ToolbarRadioButtonStyle" TargetType="RadioButton">
                <Setter Property="Height" Value="32"/>
                <Setter Property="Width" Value="32"/>
                <Setter Property="Padding" Value="6,0"/>
                <Setter Property="Margin" Value="1,0"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>

        <!-- Row 0: 地址栏（纯地址输入） -->
        <Border Grid.Row="0" Background="Transparent" Margin="0,4,0,4">
            <controls:AddressBarControl x:Name="AddressBarControl" Margin="8,0"/>
        </Border>
        
        <!-- Row 1: 工具栏行（导航 + 操作 + 视图 + 搜索） -->
        <Border Grid.Row="1" Background="Transparent" Margin="0,0,0,4">
            <Grid Margin="8,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- 导航按钮 -->
                    <ColumnDefinition Width="8"/>     <!-- 间距 -->
                    <ColumnDefinition Width="Auto"/>  <!-- TitleActionBar -->
                    <ColumnDefinition Width="*"/>     <!-- 填充 -->
                    <ColumnDefinition Width="Auto"/>  <!-- 视图切换 -->
                    <ColumnDefinition Width="8"/>     <!-- 间距 -->
                    <ColumnDefinition Width="Auto"/>  <!-- 搜索/筛选 -->
                </Grid.ColumnDefinitions>
                
                <!-- 导航按钮 (←→↑) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Name="NavBackBtn" FontFamily="Segoe MDL2 Assets" Content="&#xE72B;" FontSize="14" Click="NavBackBtn_Click" ToolTip="后退" Style="{StaticResource ModernToolbarButtonStyle}"/>
                    <Button Name="NavForwardBtn" FontFamily="Segoe MDL2 Assets" Content="&#xE72A;" FontSize="14" Click="NavForwardBtn_Click" ToolTip="前进" Style="{StaticResource ModernToolbarButtonStyle}"/>
                    <Button Name="NavUpBtn" FontFamily="Segoe MDL2 Assets" Content="&#xE74A;" FontSize="14" Click="NavUpBtn_Click" ToolTip="向上" Style="{StaticResource ModernToolbarButtonStyle}"/>
                </StackPanel>
                
                <!-- TitleActionBar (操作按钮) -->
                <controls:TitleActionBar Grid.Column="2" x:Name="TitleActionBar" Mode="Path"/>
                
                <!-- 视图切换按钮 -->
                <StackPanel Grid.Column="4" Orientation="Horizontal">
                    <RadioButton Name="ViewListBtn" Content="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                ToolTip="列表视图" Click="ViewModeBtn_Click" 
                                Style="{StaticResource ToolbarRadioButtonStyle}"
                                IsChecked="True" Tag="List"/>
                    <RadioButton Name="ViewThumbBtn" Content="&#xE8B9;" FontFamily="Segoe MDL2 Assets" FontSize="14" 
                                ToolTip="缩略图视图" Click="ViewModeBtn_Click" 
                                Style="{StaticResource ToolbarRadioButtonStyle}"
                                Tag="Thumbnail"/>
                </StackPanel>
                
                <!-- 搜索/筛选按钮 -->
                <StackPanel Grid.Column="6" Orientation="Horizontal">
                    <Button Name="SearchBtn" Content="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                            Click="SearchBtn_Click" Margin="0,0,6,0"
                            Style="{StaticResource ModernToolbarButtonStyle}" ToolTip="搜索"/>
                    <Button Name="FilterBtn" Content="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                            Click="FilterBtn_Click"
                            Style="{StaticResource ModernToolbarButtonStyle}" ToolTip="设置"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Row 2: 文件列表 -->
        <controls:FileListControl Grid.Row="2" x:Name="FileList"/>
        
        <!-- Row 3: 水平分割器（文件列表与信息面板之间） -->
        <controls:CollapsibleGridSplitter Grid.Row="3" 
                      Style="{StaticResource HorizontalCollapsibleGridSplitterStyle}"
                      CollapseMode="Both"
                      HorizontalAlignment="Stretch"
                      Panel.ZIndex="999"
                      AutoFillNeighbor="True"
                      DragCompleted="GridSplitter_DragCompleted"/>
        
        <!-- Row 4: 文件详细信息 -->
        <Border Grid.Row="4" Background="{DynamicResource BackgroundPrimaryBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8,4">
                <!-- 文件信息面板 -->
                <StackPanel x:Name="FileInfoPanel" Margin="4"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
