<UserControl x:Class="OoiMRR.Controls.FileBrowserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:OoiMRR.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="180" MinHeight="120"/>
        </Grid.RowDefinitions>
        
        <Grid.Resources>
            <Style x:Key="ToolbarRadioButtonStyle" TargetType="RadioButton">
                <Setter Property="Background" Value="#E3F2FD"/>
                <Setter Property="BorderBrush" Value="#BBDEFB"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Margin" Value="0,0,4,0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="2">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#BBDEFB"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Background" Value="#2196F3"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="#1976D2"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>

        <!-- 地址栏 -->
        <Border Grid.Row="0" Background="#F8F9FA" Margin="0,2,0,4">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- 导航按钮（← → ↑） -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Button Name="NavBackBtn" Content="←" Width="28" Height="28" Click="NavBackBtn_Click" 
                            Background="#E3F2FD" BorderBrush="#BBDEFB" BorderThickness="1" 
                            Cursor="Hand" Margin="0,0,6,0"
                            ToolTip="后退">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#E3F2FD"/>
                                <Setter Property="BorderBrush" Value="#BBDEFB"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#BBDEFB"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#90CAF9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Name="NavForwardBtn" Content="→" Width="28" Height="28" Click="NavForwardBtn_Click" 
                            Background="#E3F2FD" BorderBrush="#BBDEFB" BorderThickness="1" 
                            Cursor="Hand" Margin="0,0,6,0"
                            ToolTip="前进">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#E3F2FD"/>
                                <Setter Property="BorderBrush" Value="#BBDEFB"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#BBDEFB"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#90CAF9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Name="NavUpBtn" Content="↑" Width="28" Height="28" Click="NavUpBtn_Click" 
                            Background="#E3F2FD" BorderBrush="#BBDEFB" BorderThickness="1" 
                            Cursor="Hand"
                            ToolTip="向上">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#E3F2FD"/>
                                <Setter Property="BorderBrush" Value="#BBDEFB"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#BBDEFB"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#90CAF9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
                
                <controls:AddressBarControl Grid.Column="1" x:Name="AddressBarControl"/>
                
                <!-- 搜索 / 筛选按钮组 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- 视图切换按钮 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                        <RadioButton Name="ViewListBtn" Content="☰" Width="28" Height="28" 
                                ToolTip="列表视图" Click="ViewModeBtn_Click" 
                                Style="{StaticResource ToolbarRadioButtonStyle}"
                                IsChecked="True" Tag="List"/>
                        <RadioButton Name="ViewThumbBtn" Content="▤" Width="28" Height="28" 
                                ToolTip="缩略图视图" Click="ViewModeBtn_Click" 
                                Style="{StaticResource ToolbarRadioButtonStyle}"
                                Tag="Thumbnail"/>
                    </StackPanel>

                    <Button Name="SearchBtn" Content="🔍" Width="32" Height="28" 
                            Click="SearchBtn_Click" Margin="8,0,0,0"
                            Background="#E3F2FD" BorderBrush="#BBDEFB" BorderThickness="1" 
                            Cursor="Hand" ToolTip="搜索">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#E3F2FD"/>
                                <Setter Property="BorderBrush" Value="#BBDEFB"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#BBDEFB"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#90CAF9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Name="FilterBtn" Content="⚙" Width="32" Height="28" 
                            Click="FilterBtn_Click" Margin="6,0,0,0"
                            Background="#E3F2FD" BorderBrush="#BBDEFB" BorderThickness="1" 
                            Cursor="Hand" ToolTip="筛选">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#E3F2FD"/>
                                <Setter Property="BorderBrush" Value="#BBDEFB"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#BBDEFB"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#90CAF9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- 标签页管理 -->
        <controls:TabManagerControl Grid.Row="1" x:Name="TabManager"/>
        
        <!-- 文件列表 -->
        <controls:FileListControl Grid.Row="2" x:Name="FileList"/>
        
        <!-- 水平分割器 -->
        <GridSplitter Grid.Row="3" Style="{StaticResource HorizontalGridSplitterStyle}"
                      HorizontalAlignment="Stretch"/>
        
        <!-- 文件详细信息 -->
        <Border Grid.Row="4" Background="#F8F9FA" BorderBrush="#E9ECEF" BorderThickness="0,1,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8,4">
                <StackPanel x:Name="FileInfoPanel" Margin="4"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>

