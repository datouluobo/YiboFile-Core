<UserControl x:Class="OoiMRR.Controls.FileBrowserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:OoiMRR.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Row 0: 地址栏 -->
            <RowDefinition Height="Auto"/>  <!-- Row 1: 工具栏行 -->
            <RowDefinition Height="Auto"/>  <!-- Row 2: 搜索状态提示 -->
            <RowDefinition Height="*"/>     <!-- Row 3: 文件列表 -->
            <RowDefinition Height="12"/>     <!-- Row 4: Splitter -->
            <RowDefinition Height="180" MinHeight="120"/> <!-- Row 5: Info Panel -->
        </Grid.RowDefinitions>
        
        <Grid.Resources>
            <!-- 统一使用 AppStyles 中的 ModernToolbarButtonStyle -->
            <Style x:Key="ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernToolbarButtonStyle}"/>
            
            <Style x:Key="ToolbarRadioButtonStyle" TargetType="RadioButton">
                <Setter Property="Height" Value="32"/>
                <Setter Property="Width" Value="32"/>
                <Setter Property="Padding" Value="6,0"/>
                <Setter Property="Margin" Value="1,0"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            
            <!-- 分段按钮样式（用于搜索模式切换） -->
            <Style x:Key="SegmentedButtonStyle" TargetType="RadioButton">
                <Setter Property="Height" Value="26"/>
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource ForegroundSecondaryBrush}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}" 
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AccentSubtleBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            
            <!-- 过滤器芯片样式 -->
            <Style x:Key="FilterChipStyle" TargetType="ToggleButton">
                <Setter Property="Width" Value="28"/>
                <Setter Property="Height" Value="24"/>
                <Setter Property="Padding" Value="4"/>
                <Setter Property="Margin" Value="1,0"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AccentSubtleBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>

        <!-- Row 0: 地址栏（纯地址输入） -->
        <Border Grid.Row="0" Background="Transparent" Margin="0,4,0,4">
            <controls:AddressBarControl x:Name="AddressBarControl" Margin="8,0"/>
        </Border>
        
        <!-- Row 1: 工具栏行（导航 + 操作 + 视图 + 搜索） -->
        <Border Grid.Row="1" Background="Transparent" Margin="0,0,0,4">
            <Grid Margin="8,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- 导航按钮 -->
                    <ColumnDefinition Width="8"/>     <!-- 间距 -->
                    <ColumnDefinition Width="Auto"/>  <!-- TitleActionBar -->
                    <ColumnDefinition Width="*"/>     <!-- 填充 -->
                    <ColumnDefinition Width="Auto"/>  <!-- 视图切换 -->
                    <ColumnDefinition Width="8"/>     <!-- 间距 -->
                    <ColumnDefinition Width="Auto"/>  <!-- 搜索/筛选 -->
                </Grid.ColumnDefinitions>
                
                <!-- 导航按钮 (←→↑) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Name="NavBackBtn" FontFamily="{DynamicResource IconFontFamily}" Content="{DynamicResource Icon_Back}" FontSize="14" Click="NavBackBtn_Click" ToolTip="后退" Style="{StaticResource ModernToolbarButtonStyle}"/>
                    <Button Name="NavForwardBtn" FontFamily="{DynamicResource IconFontFamily}" Content="{DynamicResource Icon_Forward}" FontSize="14" Click="NavForwardBtn_Click" ToolTip="前进" Style="{StaticResource ModernToolbarButtonStyle}"/>
                    <Button Name="NavUpBtn" FontFamily="{DynamicResource IconFontFamily}" Content="{DynamicResource Icon_Up}" FontSize="14" Click="NavUpBtn_Click" ToolTip="向上" Style="{StaticResource ModernToolbarButtonStyle}"/>
                </StackPanel>
                
                <!-- TitleActionBar (操作按钮) -->
                <controls:TitleActionBar Grid.Column="2" x:Name="TitleActionBar" Mode="Path"/>
                
                <!-- 视图切换按钮 -->
                <StackPanel Grid.Column="4" Orientation="Horizontal">
                    <RadioButton Name="ViewListBtn" Content="{DynamicResource Icon_ViewList}" FontFamily="{DynamicResource IconFontFamily}" FontSize="14"
                                ToolTip="列表视图" Click="ViewModeBtn_Click" 
                                Style="{StaticResource ToolbarRadioButtonStyle}"
                                IsChecked="True" Tag="List"/>
                    <RadioButton Name="ViewThumbBtn" Content="{DynamicResource Icon_ViewThumb}" FontFamily="{DynamicResource IconFontFamily}" FontSize="14" 
                                ToolTip="缩略图视图" Click="ViewModeBtn_Click" 
                                Style="{StaticResource ToolbarRadioButtonStyle}"
                                Tag="Thumbnail"/>
                </StackPanel>
                
                <!-- 搜索/筛选按钮 -->
                <StackPanel Grid.Column="6" Orientation="Horizontal">
                    <!-- 搜索模式分段按钮 -->
                    <Border Background="{DynamicResource ControlBackgroundBrush}" 
                            CornerRadius="4" BorderBrush="{DynamicResource BorderDefaultBrush}" 
                            BorderThickness="1" Margin="0,0,8,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="SearchModeFileName" Content="📁 文件" 
                                        Style="{StaticResource SegmentedButtonStyle}"
                                        IsChecked="True" Tag="FileName"
                                        Checked="SearchMode_Checked" ToolTip="按文件名搜索"/>
                            <Border Width="1" Background="{DynamicResource BorderDefaultBrush}" Margin="0,4"/>
                            <RadioButton x:Name="SearchModeTags" Content="🏷️ 标签" 
                                        Style="{StaticResource SegmentedButtonStyle}"
                                        Tag="Tags" Checked="SearchMode_Checked" ToolTip="按标签搜索"/>
                            <Border Width="1" Background="{DynamicResource BorderDefaultBrush}" Margin="0,4"/>
                            <RadioButton x:Name="SearchModeNotes" Content="📝 备注" 
                                        Style="{StaticResource SegmentedButtonStyle}"
                                        Tag="Notes" Checked="SearchMode_Checked" ToolTip="按备注搜索"/>
                        </StackPanel>
                    </Border>
                    <Button Name="SearchBtn" Content="{DynamicResource Icon_Search}" FontFamily="{DynamicResource IconFontFamily}" FontSize="14"
                            Click="SearchBtn_Click" Margin="0,0,6,0"
                            Style="{StaticResource ModernToolbarButtonStyle}" ToolTip="搜索"/>
                    <Button Name="FilterBtn" Content="{DynamicResource Icon_Filter}" FontFamily="{DynamicResource IconFontFamily}" FontSize="14"
                            Click="FilterBtn_Click"
                            Style="{StaticResource ModernToolbarButtonStyle}" ToolTip="高级筛选"/>
                    
                    <!-- 快捷类型过滤器芯片 -->
                    <Border Width="1" Background="{DynamicResource BorderDefaultBrush}" Margin="6,4"/>
                    <StackPanel Orientation="Horizontal">
                        <ToggleButton x:Name="FilterImages" Content="🖼️" FontSize="12" 
                                     Style="{StaticResource FilterChipStyle}" ToolTip="图片"
                                     Click="FilterChip_Click" Tag="Images"/>
                        <ToggleButton x:Name="FilterVideos" Content="🎬" FontSize="12"
                                     Style="{StaticResource FilterChipStyle}" ToolTip="视频"
                                     Click="FilterChip_Click" Tag="Videos"/>
                        <ToggleButton x:Name="FilterDocs" Content="📄" FontSize="12"
                                     Style="{StaticResource FilterChipStyle}" ToolTip="文档"
                                     Click="FilterChip_Click" Tag="Documents"/>
                        <ToggleButton x:Name="FilterFolders" Content="📁" FontSize="12"
                                     Style="{StaticResource FilterChipStyle}" ToolTip="文件夹"
                                     Click="FilterChip_Click" Tag="Folders"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Row 2: 搜索状态提示条 -->
        <Border x:Name="SearchStatusBar" Grid.Row="2" Background="{DynamicResource AccentSubtleBrush}" 
                Visibility="Collapsed" Padding="8,4" Margin="0,0,0,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="SearchStatusIcon" Text="🔍" Margin="0,0,6,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="SearchStatusText" Text="搜索中..." 
                          Foreground="{DynamicResource ForegroundBrush}" FontSize="12" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
        
        <!-- Row 3: 文件列表 -->
        <controls:FileListControl Grid.Row="3" x:Name="FileList" FocusVisualStyle="{x:Null}"/>
        
        <!-- Row 4: 水平分割器（文件列表与信息面板之间） -->
        <controls:CollapsibleGridSplitter Grid.Row="4" 
                      Style="{StaticResource HorizontalCollapsibleGridSplitterStyle}"
                      CollapseMode="Both"
                      HorizontalAlignment="Stretch"
                      Panel.ZIndex="999"
                      AutoFillNeighbor="True"
                      ShowsPreview="True"/>
        
        <!-- Row 5: 右侧信息面板（现在移动到底部作为信息栏） -->
        <Border Grid.Row="5" Background="{DynamicResource AppBackgroundBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8,4">
                <!-- 文件信息面板 -->
                <StackPanel x:Name="FileInfoPanel" Margin="4"/>
            </ScrollViewer>
        </Border>

        <!-- 焦点边框覆盖层 (Grid.RowSpan="5") -->
        <Border x:Name="FocusBorder"
                Grid.Row="0" Grid.RowSpan="5"
                BorderThickness="2"
                BorderBrush="Transparent"
                IsHitTestVisible="False"
                Panel.ZIndex="1000"/>
    </Grid>
</UserControl>
