<UserControl x:Class="OoiMRR.Controls.FileBrowserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:OoiMRR.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="180" MinHeight="120"/>
        </Grid.RowDefinitions>

        <!-- 地址栏 -->
        <Border Grid.Row="0" Background="#F8F9FA" Margin="0,2,0,4">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- 导航按钮（← → ↑） -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Button Name="NavBackBtn" Content="←" Width="28" Height="28" Click="NavBackBtn_Click" 
                            Background="#E3F2FD" BorderBrush="#BBDEFB" BorderThickness="1" 
                            Cursor="Hand" Margin="0,0,6,0"
                            ToolTip="后退">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#E3F2FD"/>
                                <Setter Property="BorderBrush" Value="#BBDEFB"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#BBDEFB"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#90CAF9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Name="NavForwardBtn" Content="→" Width="28" Height="28" Click="NavForwardBtn_Click" 
                            Background="#E3F2FD" BorderBrush="#BBDEFB" BorderThickness="1" 
                            Cursor="Hand" Margin="0,0,6,0"
                            ToolTip="前进">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#E3F2FD"/>
                                <Setter Property="BorderBrush" Value="#BBDEFB"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#BBDEFB"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#90CAF9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Name="NavUpBtn" Content="↑" Width="28" Height="28" Click="NavUpBtn_Click" 
                            Background="#E3F2FD" BorderBrush="#BBDEFB" BorderThickness="1" 
                            Cursor="Hand"
                            ToolTip="向上">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#E3F2FD"/>
                                <Setter Property="BorderBrush" Value="#BBDEFB"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#BBDEFB"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#90CAF9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
                
                <controls:AddressBarControl Grid.Column="1" x:Name="AddressBarControl"/>
                
                <!-- 搜索 / 筛选按钮组 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Name="SearchBtn" Content="🔍" Width="32" Height="28" 
                            Click="SearchBtn_Click" Margin="8,0,0,0"
                            Background="#E3F2FD" BorderBrush="#BBDEFB" BorderThickness="1" 
                            Cursor="Hand" ToolTip="搜索">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#E3F2FD"/>
                                <Setter Property="BorderBrush" Value="#BBDEFB"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#BBDEFB"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#90CAF9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Name="FilterBtn" Content="⚙" Width="32" Height="28" 
                            Click="FilterBtn_Click" Margin="6,0,0,0"
                            Background="#E3F2FD" BorderBrush="#BBDEFB" BorderThickness="1" 
                            Cursor="Hand" ToolTip="筛选">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#E3F2FD"/>
                                <Setter Property="BorderBrush" Value="#BBDEFB"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#BBDEFB"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#90CAF9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- 标签页区域（仅在路径模式下显示） + 视图切换 -->
        <Border Grid.Row="1" x:Name="TabsBorder" Background="#F8F9FA" BorderBrush="#E9ECEF" BorderThickness="0,0,0,1" Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect Color="#20000000" Direction="270" ShadowDepth="1" Opacity="0.2" BlurRadius="3"/>
            </Border.Effect>
            <Grid Margin="6,4,6,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- 标签 -->
                <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="TabsPanel" Orientation="Horizontal"/>
                </ScrollViewer>
                <!-- 视图切换按钮 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0,0,0">
                    <StackPanel.Resources>
                        <Style x:Key="ViewToggleButtonStyle" TargetType="Button">
                            <Setter Property="Width" Value="26"/>
                            <Setter Property="Height" Value="22"/>
                            <Setter Property="Margin" Value="0,0,4,0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Background" Value="#E9ECEF"/>
                            <Setter Property="BorderBrush" Value="#CED4DA"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#DEE2E6"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#ADB5BD"/>
                                    <Setter Property="BorderBrush" Value="#ADB5BD"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Resources>
                    <Button x:Name="BtnViewDetails"
                            Style="{StaticResource ViewToggleButtonStyle}"
                            Click="BtnViewDetails_Click"
                            ToolTip="详细信息视图">
                        <Path Data="M0,0 L8,0 L8,2 L0,2 Z M0,4 L8,4 L8,6 L0,6 Z M0,8 L8,8 L8,10 L0,10 Z"
                              Fill="#495057" Stretch="Fill" Width="12" Height="12"/>
                    </Button>
                    <Button x:Name="BtnViewTiles"
                            Style="{StaticResource ViewToggleButtonStyle}"
                            Click="BtnViewTiles_Click"
                            ToolTip="缩略图视图">
                        <Grid Width="12" Height="12">
                            <Rectangle Width="5" Height="5" Fill="#495057" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                            <Rectangle Width="5" Height="5" Fill="#495057" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                            <Rectangle Width="5" Height="5" Fill="#495057" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                            <Rectangle Width="5" Height="5" Fill="#495057" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                        </Grid>
                    </Button>
                    <!-- 缩略图大小调节，仅在缩略图视图下有意义 -->
                    <Slider x:Name="ThumbnailSizeSlider"
                            Minimum="80"
                            Maximum="256"
                            Value="128"
                            Width="80"
                            Margin="4,0,0,0"
                            VerticalAlignment="Center"
                            ToolTip="缩略图大小"
                            ValueChanged="ThumbnailSizeSlider_ValueChanged"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- 文件列表 -->
        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#E9ECEF" BorderThickness="0,1,0,0">
            <Grid>
                <ListView x:Name="FilesListView" 
                      SelectionMode="Extended"
                      Background="#FFFFFF">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="#FFFFFF"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#64B5F6"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsSelected" Value="True"/>
                                        <Condition Property="IsMouseOver" Value="True"/>
                                    </MultiTrigger.Conditions>
                                    <Setter Property="Background" Value="#42A5F5"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                </MultiTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E3F2FD"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView x:Name="FilesGridView">
                            <GridViewColumn Width="200" DisplayMemberBinding="{Binding Name}">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="名称" Tag="Name"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn x:Name="ColSize" Width="100" DisplayMemberBinding="{Binding Size}">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="大小" Tag="Size"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn x:Name="ColType" Width="100" DisplayMemberBinding="{Binding Type}">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="类型" Tag="Type"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn Width="150" DisplayMemberBinding="{Binding ModifiedDate}">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="修改日期" Tag="ModifiedDate"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn Width="50">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="创建" Tag="CreatedTime"/>
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <TextBlock.Text>
                                                <Binding Path="CreatedTime"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="150" DisplayMemberBinding="{Binding Tags}">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="标签" Tag="Tags"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn Width="200" DisplayMemberBinding="{Binding Notes}">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="备注" Tag="Notes"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
                <!-- 加载更多按钮 -->
                <Button x:Name="LoadMoreBtn" Content="加载更多" Width="88" Height="28"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="8"
                        Visibility="Collapsed" Click="LoadMoreBtn_Click"/>
                
                <!-- 空状态提示 -->
                <TextBlock x:Name="EmptyStateText" 
                           Text="暂无文件"
                           FontSize="16"
                           Foreground="#999999"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed"/>
            </Grid>
        </Border>
        
        <!-- 水平分割器 -->
        <GridSplitter Grid.Row="3" Style="{StaticResource HorizontalGridSplitterStyle}"
                      HorizontalAlignment="Stretch"/>
        
        <!-- 文件详细信息 -->
        <Border Grid.Row="4" Background="#F8F9FA" BorderBrush="#E9ECEF" BorderThickness="0,1,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8,4">
                <StackPanel x:Name="FileInfoPanel" Margin="4"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>

