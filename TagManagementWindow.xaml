<Window x:Class="OoiMRR.TagManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="管理标签" Height="600" Width="800"
        WindowStartupLocation="CenterOwner">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标签列表 -->
        <GroupBox Grid.Row="0" Header="标签列表" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <ListBox Grid.Column="0" Name="TagsListBox" 
                         SelectionChanged="TagsListBox_SelectionChanged"
                         Margin="5">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Count, StringFormat='使用次数: {0}'}" Foreground="Gray" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                
                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="5,0,0,0">
                    <Button Content="新建标签" Click="NewTag_Click" Margin="0,0,0,5" Padding="10,5"/>
                    <Button Content="重命名" Click="RenameTag_Click" Margin="0,0,0,5" Padding="10,5"/>
                    <Button Content="删除标签" Click="DeleteTag_Click" Margin="0,0,0,5" Padding="10,5"/>
                    <Button Content="清理重复标签" Click="ConsolidateTags_Click" Padding="10,5"/>
                </StackPanel>
            </Grid>
        </GroupBox>
        
        <!-- 标签统计信息 -->
        <GroupBox Grid.Row="1" Header="标签统计" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Name="TotalTagsText" Text="总标签数: 0" Margin="0,0,0,5"/>
                <TextBlock Grid.Row="1" Name="TotalSamplesText" Text="总样本数: 0" Margin="0,0,0,5"/>
                <TextBlock Grid.Row="2" Name="ManualSamplesText" Text="手动标注: 0" Margin="0,0,0,5"/>
                <TextBlock Grid.Row="3" Name="UniqueImagesText" Text="唯一图片: 0" Margin="0,0,0,5"/>
                
                <!-- 训练状态 -->
                <StackPanel Grid.Row="4" Orientation="Vertical" Margin="0,10,0,0">
                    <TextBlock Text="模型状态:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock Name="ModelStatusText" Text="检查中..." Foreground="Gray"/>
                    <Button Content="🔄 重新训练模型" Click="RetrainModel_Click" 
                           Name="RetrainModelBtn" Margin="0,10,0,0" Padding="10,5" HorizontalAlignment="Left"/>
                    <Button Content="📈 训练情况" Click="TrainingStatus_Click" 
                           Margin="0,5,0,0" Padding="10,5" HorizontalAlignment="Left"/>
                </StackPanel>
            </Grid>
        </GroupBox>
        
        <!-- 训练进度 -->
        <Grid Grid.Row="2" Margin="0,0,0,10" Visibility="Collapsed" Name="TrainingProgressGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Name="TrainingStageText" Text="" 
                      FontSize="12" FontWeight="Bold" Margin="0,0,0,5"/>
            <ProgressBar Grid.Row="1" Name="TrainingProgressBar" 
                        Height="20" Minimum="0" Maximum="100" Value="0"/>
            <TextBlock Grid.Row="2" Name="TrainingProgressText" Text="" 
                      FontSize="11" Foreground="Gray" Margin="0,5,0,0"/>
        </Grid>
        
        <!-- 按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="关闭" Click="Close_Click" Padding="20,5"/>
        </StackPanel>
    </Grid>
</Window>






