<Window x:Class="OoiMRR.LibraryManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="管理库" Height="500" Width="700"
        WindowStartupLocation="CenterOwner">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 库列表 -->
        <GroupBox Grid.Row="0" Header="库列表" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <ListBox Grid.Column="0" Name="LibrariesListBox" 
                         SelectionChanged="LibrariesListBox_SelectionChanged"
                         DisplayMemberPath="Name"
                         Margin="5"/>
                
                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="5,0,0,0">
                    <Button Content="新建库" Click="NewLibrary_Click" Margin="0,0,0,5" Padding="10,5"/>
                    <Button Content="重命名" Click="RenameLibrary_Click" Margin="0,0,0,5" Padding="10,5"/>
                    <Button Content="删除库" Click="DeleteLibrary_Click" Padding="10,5"/>
                </StackPanel>
            </Grid>
        </GroupBox>
        
        <!-- 库位置列表 -->
        <GroupBox Grid.Row="1" Header="库位置" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <ListBox Grid.Row="0" Name="PathsListBox" Margin="5"
                         SelectionChanged="PathsListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding Path}" Foreground="Gray"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5,10,5,5">
                    <Button Content="添加位置" Click="AddPath_Click" Margin="0,0,5,0" Padding="10,5"/>
                    <Button Content="删除位置" Click="RemovePath_Click" Padding="10,5"/>
                </StackPanel>
            </Grid>
        </GroupBox>
        
        <!-- 按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="关闭" Click="Close_Click" Padding="20,5"/>
        </StackPanel>
    </Grid>
</Window>
