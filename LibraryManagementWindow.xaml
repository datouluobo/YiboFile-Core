<Window x:Class="OoiMRR.LibraryManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="管理库" Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        MinWidth="500" MinHeight="400"
        ResizeMode="CanResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="📚 库管理" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

        <!-- 库列表 -->
        <GroupBox Grid.Row="1" Header="库列表" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ListBox Grid.Row="0" Name="LibrariesListBox" 
                         SelectionChanged="LibrariesListBox_SelectionChanged"
                         DisplayMemberPath="Name"
                         Margin="0,0,0,10"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="🔼" Click="MoveLibraryUp_Click" 
                           Name="MoveUpBtn" Height="30" FontSize="12" 
                           IsEnabled="False" Margin="0,0,8,0" Width="36" ToolTip="上移"/>
                    <Button Content="🔽" Click="MoveLibraryDown_Click" 
                           Name="MoveDownBtn" Height="30" FontSize="12" 
                           IsEnabled="False" Margin="0,0,16,0" Width="36" ToolTip="下移"/>
                    <Button Content="✏️ 编辑库" Click="RenameLibrary_Click" 
                           Name="RenameLibraryBtn" Height="30" FontSize="12" 
                           IsEnabled="False" Margin="0,0,8,0" MinWidth="100"/>
                    <Button Content="🗑️ 删除库" Click="DeleteLibrary_Click" 
                           Name="DeleteLibraryBtn" Height="30" FontSize="12" 
                           IsEnabled="False" MinWidth="100"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- 新建库区域 -->
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Name="NewLibraryNameTextBox" Grid.Column="0" 
                     Height="32" FontSize="13" VerticalContentAlignment="Center"
                     Padding="8,0" Margin="0,0,10,0"
                     KeyDown="NewLibraryNameTextBox_KeyDown"
                     ToolTip="输入库名称后按回车或点击新建按钮"/>
            <Button Grid.Column="1" Content="➕ 新建库" Click="NewLibrary_Click" 
                   Height="32" FontSize="12" MinWidth="100" Padding="15,0"/>
        </Grid>

        <!-- 库位置列表 -->
        <GroupBox Grid.Row="3" Header="库位置" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ListBox Grid.Row="0" Name="PathsListBox" Margin="0,0,0,10"
                         SelectionChanged="PathsListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding Path}" Foreground="Gray"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="添加位置" Click="AddPath_Click" 
                           Name="AddPathBtn" Height="30" FontSize="12" 
                           IsEnabled="False" Margin="0,0,8,0" MinWidth="100"/>
                    <Button Content="删除位置" Click="RemovePath_Click" 
                           Name="RemovePathBtn" Height="30" FontSize="12" 
                           IsEnabled="False" MinWidth="100"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="确定" Click="OK_Click" 
                   Height="35" FontSize="13" MinWidth="80" Margin="0,0,10,0"/>
            <Button Content="取消" Click="Cancel_Click" 
                   Height="35" FontSize="13" MinWidth="80"/>
        </StackPanel>
    </Grid>
</Window>
