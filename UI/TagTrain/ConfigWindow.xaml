<Window x:Class="TagTrain.UI.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="配置" Height="450" Width="600"
        WindowStartupLocation="Manual"
        MinWidth="500" MinHeight="400"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        Closing="Window_Closing"
        LocationChanged="Window_LocationChanged"
        SizeChanged="Window_SizeChanged"
        SourceInitialized="Window_SourceInitialized"
        Loaded="Window_Loaded">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Content="图片目录:" FontSize="14" Margin="0,0,0,8"/>
        
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Name="DirectoryTextBox" Grid.Column="0" MinHeight="28"
                    FontFamily="Segoe UI" FontSize="13" Padding="8,4"
                    VerticalContentAlignment="Center" Margin="0,0,10,0"
                    TextChanged="DirectoryTextBox_TextChanged">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="BorderBrush" Value="#CCCCCC"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TextBox">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6">
                                        <ScrollViewer x:Name="PART_ContentHost"
                                                      Margin="{TemplateBinding Padding}"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#2196F3"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
            <Button Content="浏览..." Grid.Column="1" Click="Browse_Click" 
                   Width="80" Height="30"/>
        </Grid>

        <TextBlock Grid.Row="2" Name="StatusText" Foreground="Gray" 
                  FontSize="12" Margin="0,0,0,15"/>

        <Label Grid.Row="3" Content="设置及数据保存路径:" FontSize="14" Margin="0,0,0,8"/>
        
        <Grid Grid.Row="4" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Name="DataStoragePathTextBox" Grid.Column="0" MinHeight="28"
                    FontFamily="Segoe UI" FontSize="13" Padding="8,4"
                    VerticalContentAlignment="Center" Margin="0,0,10,0"
                    IsReadOnly="True" IsReadOnlyCaretVisible="False">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="BorderBrush" Value="#CCCCCC"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TextBox">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6">
                                        <ScrollViewer x:Name="PART_ContentHost"
                                                      Margin="{TemplateBinding Padding}"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#2196F3"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
            <Button Content="选择文件夹" Grid.Column="1" Click="SelectDataStorageFolder_Click" 
                   Width="100" Height="30"/>
        </Grid>
        
        <TextBlock Grid.Row="5" Text="程序将从此目录加载数据: settings.txt, training.db, model.zip（不迁移旧数据）" 
                  FontSize="11" Foreground="Gray" Margin="0,0,0,15" TextWrapping="Wrap"/>

        <Label Grid.Row="6" Content="标签显示设置:" FontSize="14" Margin="0,0,0,8" FontWeight="Bold"/>
        
        <Grid Grid.Row="7" Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="每行显示标签数:" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Slider Name="TagsPerRowSlider" Grid.Column="1" Minimum="1" Maximum="10" 
                       TickFrequency="1" IsSnapToTickEnabled="True" 
                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Name="TagsPerRowValue" Grid.Column="2" Text="5" FontSize="12" 
                          VerticalAlignment="Center" MinWidth="30"/>
            </Grid>
            
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="预测阈值（%）:" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Slider Name="PredictionThresholdSlider" Grid.Column="1" Minimum="0" Maximum="100" 
                       TickFrequency="5" IsSnapToTickEnabled="True" 
                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Name="PredictionThresholdValue" Grid.Column="2" Text="50" FontSize="12" 
                          VerticalAlignment="Center" MinWidth="40"/>
            </Grid>
        </Grid>

        <StackPanel Grid.Row="8" Orientation="Horizontal" 
                   HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="确定" Click="OK_Click" Width="80" Height="35" 
                   Margin="0,0,10,0" IsDefault="True"/>
            <Button Content="取消" Click="Cancel_Click" Width="80" Height="35"/>
        </StackPanel>
    </Grid>
</Window>

