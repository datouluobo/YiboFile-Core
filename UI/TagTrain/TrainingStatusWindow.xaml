<Window x:Class="TagTrain.UI.TrainingStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="训练情况" Height="680" Width="700"
        WindowStartupLocation="Manual"
        MinWidth="600" MinHeight="500"
        SourceInitialized="Window_SourceInitialized"
        Closing="Window_Closing"
        LocationChanged="Window_LocationChanged"
        SizeChanged="Window_SizeChanged">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="ML模型训练状态" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 模型状态 -->
                <GroupBox Header="模型状态" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="模型文件:" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Name="ModelPathText" Text="-" TextWrapping="Wrap"/>
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="模型状态:" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Name="ModelStatusText" Text="未加载"/>
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="模型大小:" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Name="ModelSizeText" Text="-"/>
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="最后更新:" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Name="ModelLastUpdateText" Text="-"/>
                        </Grid>
                        <Button Content="🔍 验证模型文件" Click="ValidateModel_Click" 
                               Name="ValidateModelBtn" Height="35" FontSize="13" Margin="0,10,0,0"/>
                        <TextBlock Name="ValidationResultText" Text="" 
                                  Margin="0,10,0,0" TextWrapping="Wrap" 
                                  Visibility="Collapsed"/>
                    </StackPanel>
                </GroupBox>

                <!-- 训练数据 -->
                <GroupBox Header="训练数据" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="总样本数:" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Name="TotalSamplesText" Text="0"/>
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="手动标注:" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Name="ManualSamplesText" Text="0"/>
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="唯一图片:" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Name="UniqueImagesText" Text="0"/>
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="唯一标签:" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Name="UniqueTagsText" Text="0"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- 模型测试 -->
                <GroupBox Header="模型测试" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="测试说明: 模型可以正常预测时，说明ML工作正常" 
                                  TextWrapping="Wrap" Margin="0,0,0,10" Foreground="Gray"/>
                        <Button Content="🧪 测试模型预测" Click="TestModel_Click" 
                               Name="TestModelBtn" Height="35" FontSize="13"/>
                        <TextBlock Name="TestResultText" Text="" 
                                  Margin="0,10,0,0" TextWrapping="Wrap" 
                                  Foreground="Green" Visibility="Collapsed"/>
                    </StackPanel>
                </GroupBox>

                <!-- 系统信息 -->
                <GroupBox Header="系统信息" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ML.NET版本:" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Name="MLNetVersionText" Text="3.0.0"/>
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="数据库路径:" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Name="DatabasePathText" Text="-" TextWrapping="Wrap"/>
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ML.NET状态:" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Name="MLNetStatusText" Text="检查中..." Foreground="Gray"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="2" Content="关闭" Click="Close_Click" 
               Width="80" Height="35" HorizontalAlignment="Right" Margin="0,15,0,0"/>
    </Grid>
</Window>

