<Window x:Class="TagTrain.UI.CategoryManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TagTrain.UI"
        Title="分组管理" Height="500" Width="600"
        WindowStartupLocation="CenterOwner"
        MinWidth="500" MinHeight="400"
        ResizeMode="CanResize">
    <Window.Resources>
        <local:ColorConverter x:Key="ColorConverter"/>
    </Window.Resources>
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="📁 标签分组管理" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

        <!-- 分组列表 -->
        <GroupBox Grid.Row="1" Header="分组列表" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ListBox Name="CategoriesListBox" Grid.Row="0" 
                        SelectionChanged="CategoriesListBox_SelectionChanged"
                        Margin="0,0,0,10">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Width="16" Height="16" Margin="0,0,8,0" 
                                          VerticalAlignment="Center">
                                    <Rectangle.Fill>
                                        <SolidColorBrush Color="{Binding Color, Converter={StaticResource ColorConverter}}"/>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding TagCount, StringFormat='({0})'}" 
                                          Foreground="Gray" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="🔼" Click="MoveUp_Click" 
                           Name="MoveUpBtn" Height="30" FontSize="12" 
                           IsEnabled="False" Margin="0,0,8,0" Width="36" ToolTip="上移"/>
                    <Button Content="🔽" Click="MoveDown_Click" 
                           Name="MoveDownBtn" Height="30" FontSize="12" 
                           IsEnabled="False" Margin="0,0,16,0" Width="36" ToolTip="下移"/>
                    <Button Content="✏️ 编辑分组" Click="EditCategory_Click" 
                           Name="EditCategoryBtn" Height="30" FontSize="12" 
                           IsEnabled="False" Margin="0,0,8,0" MinWidth="100"/>
                    <Button Content="🗑️ 删除分组" Click="DeleteCategory_Click" 
                           Name="DeleteCategoryBtn" Height="30" FontSize="12" 
                           IsEnabled="False" MinWidth="100"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- 新建分组区域 -->
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Name="NewCategoryNameTextBox" Grid.Column="0" 
                     Height="32" FontSize="13" VerticalContentAlignment="Center"
                     Padding="8,0" Margin="0,0,10,0"
                     KeyDown="NewCategoryNameTextBox_KeyDown"
                     ToolTip="输入分组名称后按回车或点击新建按钮"/>
            <Button Grid.Column="1" Content="➕ 新建分组" Click="NewCategory_Click" 
                   Height="32" FontSize="12" MinWidth="100" Padding="15,0"/>
        </Grid>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="确定" Click="OK_Click" 
                   Height="35" FontSize="13" MinWidth="80" Margin="0,0,10,0"/>
            <Button Content="取消" Click="Cancel_Click" 
                   Height="35" FontSize="13" MinWidth="80"/>
        </StackPanel>
    </Grid>
</Window>

