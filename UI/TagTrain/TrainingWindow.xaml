<Window x:Class="TagTrain.UI.TrainingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TagTrain.UI"
        Title="图片标签训练" Height="800" Width="1400"
        WindowStartupLocation="Manual"
        MinWidth="1000" MinHeight="600"
        Closing="Window_Closing"
        SizeChanged="Window_SizeChanged"
        LocationChanged="Window_LocationChanged"
        StateChanged="Window_StateChanged"
        SourceInitialized="Window_SourceInitialized">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部信息栏 -->
        <Border Grid.Row="0" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" Background="#F9F9F9" 
               CornerRadius="3" Padding="10,5" Margin="0,0,0,10">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📊 统计: " FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Name="StatsText" Text="总样本: 0 | 手动标注: 0 | 唯一图片: 0 | 唯一标签: 0" 
                              FontSize="12" VerticalAlignment="Center" Foreground="{DynamicResource ForegroundSecondaryBrush}" Margin="5,0,0,0"/>
                    <TextBlock Text=" | 目录图片: " FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Margin="15,0,0,0"/>
                    <TextBlock Name="DirectoryImageCountText" Text="计算中..." FontSize="12" VerticalAlignment="Center" Margin="5,0,0,0" Foreground="{DynamicResource ForegroundSecondaryBrush}"/>
                    <TextBlock Text=" | 训练进度: " FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Margin="15,0,0,0"/>
                    <TextBlock Name="ProgressText" Text="0/0" FontSize="12" VerticalAlignment="Center" Margin="5,0,0,0"/>
                    <TextBlock Text=" | 准确率: " FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Margin="15,0,0,0"/>
                    <TextBlock Name="AccuracyText" Text="0%" FontSize="12" VerticalAlignment="Center" Margin="5,0,0,0"/>
                    <TextBlock Text=" | 当前图片: " FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Margin="15,0,0,0"/>
                    <TextBlock Name="CurrentImageText" Text="-" FontSize="12" VerticalAlignment="Center" Margin="5,0,0,0" TextTrimming="CharacterEllipsis" MinWidth="150" Cursor="Hand" MouseLeftButtonDown="CurrentImageText_MouseLeftButtonDown" ToolTip="点击跳转到指定图片"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- 主内容区域：左右分区 -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：控制面板（使用TagPanel组件） -->
            <Grid Grid.Column="0" Name="LeftPanel" MouseMove="LeftPanel_MouseMove">
                <local:TagPanel x:Name="TagPanelControl" Mode="Full"/>
            </Grid>

            <!-- 分割器 -->
            <GridSplitter Name="MainGridSplitter" Grid.Column="1" Width="5" HorizontalAlignment="Stretch" 
                         VerticalAlignment="Stretch" Background="{DynamicResource BorderDefaultBrush}" 
                         ShowsPreview="True" ResizeBehavior="PreviousAndNext"
                         Opacity="0" 
                         MouseEnter="MainGridSplitter_MouseEnter" 
                         MouseLeave="MainGridSplitter_MouseLeave"
                         MouseMove="MainGridSplitter_MouseMove"/>

            <!-- 右侧：图片显示区域 -->
            <Border Grid.Column="2" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="2" 
                    Background="{DynamicResource BackgroundTertiaryBrush}" CornerRadius="5">
                <Grid ClipToBounds="True">
                    <Image Name="ImageDisplay" 
                           Stretch="Uniform" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           StretchDirection="Both"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Name="NoImageText" Text="点击'开始训练'按钮开始" 
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              FontSize="18" Foreground="Gray" Visibility="Visible"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
