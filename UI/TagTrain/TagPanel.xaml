<UserControl x:Class="TagTrain.UI.TagPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- AI预测结果 -->
        <GroupBox Grid.Row="0" Margin="0,0,0,10" Padding="8" Name="AIPredictionGroupBox">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🤖 AI预测结果" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Ellipse Name="ModelStatusIndicator" Width="12" Height="12" 
                            VerticalAlignment="Center" Margin="0,0,5,0">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="Gray"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Name="ModelStatusText" Text="检查中..." FontSize="11" 
                              VerticalAlignment="Center" Foreground="Gray"/>
                </StackPanel>
            </GroupBox.Header>
            <WrapPanel Name="PredictionPanel" Orientation="Horizontal">
                <TextBlock Text="暂无预测结果" Foreground="Gray" FontStyle="Italic" 
                          Name="NoPredictionText" Visibility="Visible"/>
            </WrapPanel>
        </GroupBox>

        <!-- 已标注标签列表 -->
        <GroupBox Grid.Row="1" Margin="0,0,0,10" Padding="8">
            <GroupBox.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="📋 已有标签（点击选择，右键删除）" VerticalAlignment="Center"/>
                    <ComboBox Name="TagSortComboBox" Grid.Column="1" Width="120" Height="25" 
                             SelectionChanged="TagSortComboBox_SelectionChanged"
                             FontSize="11" VerticalContentAlignment="Center">
                        <ComboBoxItem Content="按使用次数" Tag="Count" IsSelected="True"/>
                        <ComboBoxItem Content="按字母顺序" Tag="Name"/>
                        <ComboBoxItem Content="按预测度" Tag="Prediction"/>
                    </ComboBox>
                </Grid>
            </GroupBox.Header>
            <ScrollViewer Name="TagsScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                         ScrollChanged="TagsScrollViewer_ScrollChanged"
                         MouseMove="TagsScrollViewer_MouseMove"
                         PreviewMouseWheel="TagsScrollViewer_PreviewMouseWheel">
                <StackPanel Name="ExistingTagsPanel" Orientation="Vertical" Loaded="ExistingTagsPanel_Loaded"/>
            </ScrollViewer>
        </GroupBox>

        <!-- 标签输入区域 -->
        <GroupBox Grid.Row="2" Header="🏷️ 输入标签（按Tab键分隔）" Margin="0,0,0,10" Padding="8" Name="TagInputGroupBox">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 标签输入区域 -->
                <WrapPanel Grid.Row="0" Name="TagInputPanel" Orientation="Horizontal" Margin="0,0,0,8">
                    <Border Name="TagInputBorder" 
                           MinWidth="150" MaxWidth="300" Height="30"
                           BorderBrush="#B0B0B0"
                           BorderThickness="1"
                           Background="White"
                           CornerRadius="4"
                           Padding="1">
                        <Grid>
                            <TextBox Name="TagInputTextBox" 
                                    FontSize="13"
                                    VerticalContentAlignment="Center"
                                    Padding="7,5"
                                    BorderThickness="0"
                                    Background="Transparent"
                                    TextChanged="TagInputTextBox_TextChanged"
                                    KeyDown="TagInputTextBox_KeyDown"
                                    PreviewKeyDown="TagInputTextBox_PreviewKeyDown"
                                    GotFocus="TagInputTextBox_GotFocus"
                                    LostFocus="TagInputTextBox_LostFocus"
                                    ToolTip="输入标签后按Tab键添加，按Tab键可自动补完"/>
                            <Popup Name="TagAutocompletePopup" 
                                  Placement="Bottom"
                                  StaysOpen="True"
                                  AllowsTransparency="True"
                                  PopupAnimation="Fade"
                                  MaxHeight="200"
                                  MinWidth="150"
                                  HorizontalOffset="0"
                                  VerticalOffset="2"
                                  Focusable="False">
                                <Border BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" 
                                       Background="White" CornerRadius="4"
                                       MinWidth="150">
                                    <ListBox Name="TagAutocompleteListBox"
                                            MaxHeight="200"
                                            SelectionMode="Single"
                                            MouseDoubleClick="TagAutocompleteListBox_MouseDoubleClick"
                                            KeyDown="TagAutocompleteListBox_KeyDown"
                                            Background="White"
                                            BorderThickness="0"
                                            MinWidth="150">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" 
                                                          Padding="8,4"
                                                          FontSize="12"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="0"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#E3F2FD"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="#BBDEFB"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                </WrapPanel>

                <WrapPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="✅ 确认标签" Click="ConfirmTag_Click" 
                           MinWidth="100" Height="35" FontSize="14" Margin="0,0,10,0"
                           IsDefault="True" Name="ConfirmTagBtn"/>
                    <Button Content="🤖 确认AI预测" Click="ConfirmAIPrediction_Click" 
                           MinWidth="110" Height="35" FontSize="14" Margin="0,0,10,0"
                           Name="ConfirmAIPredictionBtn"
                           ToolTip="确认AI预测结果，自动保存为训练数据"/>
                    <Button Content="⏭️ 跳过" Click="Skip_Click" MinWidth="80" Height="35" FontSize="14" Name="SkipBtn"/>
                </WrapPanel>
            </Grid>
        </GroupBox>

        <!-- 操作按钮区域 -->
        <WrapPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10" Name="TrainingButtonsPanel">
            <Button Content="▶️ 开始训练" Click="StartTraining_Click" 
                   Name="StartTrainingBtn" Height="35" FontSize="13" Margin="0,0,8,8" MinWidth="120"/>
            <Button Content="🔄 重新训练模型" Click="RetrainModel_Click" 
                   Name="RetrainModelBtn" Height="35" FontSize="13" Margin="0,0,8,8" MinWidth="120"/>
            <Button Content="❌ 取消训练" Click="CancelTraining_Click" 
                   Name="CancelTrainingBtn" Height="35" FontSize="13" IsEnabled="False" Margin="0,0,8,8" MinWidth="100"
                   Visibility="Collapsed"/>
            <Button Content="📦 批量操作" Click="BatchOperation_Click" 
                   Name="BatchOperationBtn" Height="35" FontSize="13" Margin="0,0,8,8" MinWidth="100"/>
            <Button Content="📈 训练情况" Click="TrainingStatus_Click" 
                   Name="TrainingStatusBtn" Height="35" FontSize="13" Margin="0,0,8,8" MinWidth="100"/>
            <Button Content="🧹 清理重复标签" Click="ConsolidateTags_Click" 
                   Name="ConsolidateTagsBtn" Height="35" FontSize="13" Margin="0,0,8,8" MinWidth="120"/>
            <Button Content="📁 分组管理" Click="CategoryManagement_Click" 
                   Height="35" FontSize="13" Margin="0,0,8,8" MinWidth="100" Name="CategoryManagementBtn"/>
            <Button Content="⚙️ 设置" Click="Config_Click" 
                   Height="35" FontSize="13" Margin="0,0,0,8" MinWidth="80" Name="ConfigBtn"/>
        </WrapPanel>

        <!-- 训练进度显示 -->
        <Grid Grid.Row="4" Margin="0,0,0,10" Visibility="Collapsed" Name="TrainingProgressGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Name="TrainingStageText" Text="" 
                      FontSize="12" FontWeight="Bold" Margin="0,0,0,5"/>
            <ProgressBar Grid.Row="1" Name="TrainingProgressBar" 
                        Height="20" Minimum="0" Maximum="100" Value="0"/>
            <TextBlock Grid.Row="2" Name="TrainingProgressText" Text="" 
                      FontSize="11" Foreground="Gray" Margin="0,5,0,0"/>
        </Grid>

        <!-- 状态栏 -->
        <TextBlock Grid.Row="5" Name="StatusText" Text="就绪" 
                  VerticalAlignment="Center" Foreground="Gray" FontSize="12" 
                  TextWrapping="Wrap"/>
    </Grid>
</UserControl>





